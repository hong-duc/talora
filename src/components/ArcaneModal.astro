---
interface Props {
  id?: string;
  title?: string;
  message?: string;
  confirmLabel?: string;
  cancelLabel?: string;
  icon?: string;
}

const {
  id = "arcane-modal",
  title = "Banish this Whisper?",
  message = "Are you certain you wish to erase this echo from the archives? This action cannot be undone by any spell or scholar.",
  confirmLabel = "Banish",
  cancelLabel = "Keep Whisper",
  icon = "auto_delete",
} = Astro.props;
---

<div
  id={id}
  class="fixed inset-0 z-50 hidden items-center justify-center bg-background-dark/80 backdrop-blur-sm p-4"
>
  <div
    class="relative w-full max-w-md parchment-texture border-2 border-primary/30 rounded-lg shadow-[0_0_50px_rgba(115,17,212,0.3)] overflow-hidden"
  >
    <div
      class="absolute inset-0 opacity-10 pointer-events-none"
      style="background-image: linear-gradient(45deg, #7311d4 25%, transparent 25%, transparent 50%, #7311d4 50%, #7311d4 75%, transparent 75%, transparent); background-size: 100px 100px;"
    >
    </div>
    <div class="relative p-8 flex flex-col items-center text-center">
      <div class="mb-6 rounded-full bg-primary/10 p-4 border border-primary/30">
        <span class="material-symbols-outlined text-primary text-5xl"
          >{icon}</span
        >
      </div>
      <h3
        class="text-3xl font-bold text-slate-100 mb-4 tracking-tight"
        data-modal-title
      >
        {title}
      </h3>
      <p
        class="text-slate-300 text-lg leading-relaxed mb-8 italic"
        data-modal-message
      >
        {message}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 w-full">
        <button
          data-modal-cancel
          class="flex-1 px-6 py-3 rounded-lg border border-primary/40 text-slate-100 font-bold hover:bg-primary/10 transition-all uppercase tracking-widest text-xs"
        >
          {cancelLabel}
        </button>
        <button
          data-modal-confirm
          class="flex-1 px-6 py-3 rounded-lg bg-primary text-slate-100 font-bold hover:bg-primary/90 shadow-lg shadow-primary/40 transition-all uppercase tracking-widest text-xs"
        >
          {confirmLabel}
        </button>
      </div>
    </div>
    <!-- Decorative corners -->
    <div
      class="absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-primary/50 m-2"
    >
    </div>
    <div
      class="absolute top-0 right-0 w-8 h-8 border-t-2 border-r-2 border-primary/50 m-2"
    >
    </div>
    <div
      class="absolute bottom-0 left-0 w-8 h-8 border-b-2 border-l-2 border-primary/50 m-2"
    >
    </div>
    <div
      class="absolute bottom-0 right-0 w-8 h-8 border-b-2 border-r-2 border-primary/50 m-2"
    >
    </div>
  </div>
</div>

<style>
  .parchment-texture {
    background-color: #191022;
    background-image: radial-gradient(
      circle at 2px 2px,
      rgba(115, 17, 212, 0.05) 1px,
      transparent 0
    );
    background-size: 24px 24px;
  }
</style>

<script is:inline define:vars={{ id }}>
  (() => {
    const root = document.getElementById(id);
    if (!root || root.dataset.ready) return;
    root.dataset.ready = true;

    const titleEl = root.querySelector("[data-modal-title]");
    const messageEl = root.querySelector("[data-modal-message]");
    const confirmBtn = root.querySelector("[data-modal-confirm]");
    const cancelBtn = root.querySelector("[data-modal-cancel]");

    let currentResolve = null;

    const hide = () => {
      root.classList.add("hidden");
      root.classList.remove("flex");
    };

    const show = (detail = {}) => {
      if (typeof detail.title === "string") titleEl.textContent = detail.title;
      if (typeof detail.message === "string")
        messageEl.textContent = detail.message;
      if (typeof detail.confirmLabel === "string")
        confirmBtn.textContent = detail.confirmLabel;
      if (typeof detail.cancelLabel === "string")
        cancelBtn.textContent = detail.cancelLabel;
      if (typeof detail.icon === "string") {
        const iconEl = root.querySelector(
          ".material-symbols-outlined.text-primary",
        );
        if (iconEl) iconEl.textContent = detail.icon;
      }

      root.classList.remove("hidden");
      root.classList.add("flex");

      return new Promise((resolve) => {
        currentResolve = resolve;
      });
    };

    const onConfirm = () => {
      hide();
      if (currentResolve) currentResolve(true);
    };

    const onCancel = () => {
      hide();
      if (currentResolve) currentResolve(false);
    };

    confirmBtn.addEventListener("click", onConfirm);
    cancelBtn.addEventListener("click", onCancel);

    // Register globally
    if (!window.arcaneUI) window.arcaneUI = {};
    window.arcaneUI.modal = { show, hide };
  })();
</script>
