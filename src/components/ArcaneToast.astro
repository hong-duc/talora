---
interface Props {
	id?: string;
	variant?: "success" | "information" | "achievement";
	eyebrow?: string;
	title?: string;
	description?: string;
	icon?: string;
	duration?: number;
	floating?: boolean;
	className?: string;
}

const {
	id = "arcane-toast",
	variant = "achievement",
	eyebrow = variant === "success"
		? "Success"
		: variant === "information"
			? "Information"
			: "Achievement Unlocked",
	title = variant === "success"
		? "Scroll Saved to Vault"
		: variant === "information"
			? "A new whisper has arrived"
			: "+50 Arcane Knowledge",
	description = variant === "success"
		? "Your progress has been etched in the eternal records of the Whispering Library."
		: variant === "information"
			? "The ink on the Forbidden Section's ledger is shifting. A message awaits your eyes."
			: '"The seeker who listens to the dust becomes the master of the wind."',
	icon = variant === "success"
		? "verified"
		: variant === "information"
			? "forum"
			: "auto_awesome",
	duration = 3000,
	floating = true,
	className = "",
} = Astro.props;

const successCard =
	"border-accent-gold/30 border-l-accent-gold bg-background-dark/80 shadow-2xl";
const infoCard =
	"border-primary/40 border-l-primary bg-background-dark/80 shadow-2xl";
const achievementCard =
	"border-primary/50 border-l-primary bg-[#2a1b3d] shadow-[0_0_20px_rgba(115,17,212,0.3)]";

const cardClass =
	variant === "success"
		? successCard
		: variant === "information"
			? infoCard
			: achievementCard;

const overlayClass =
	variant === "success"
		? "bg-linear-to-r from-accent-gold/5 to-transparent"
		: variant === "information"
			? "bg-linear-to-r from-primary/10 to-transparent"
			: "bg-linear-to-r from-primary/15 to-transparent";

const iconWrapClass =
	variant === "success"
		? "bg-accent-gold/20 text-accent-gold"
		: variant === "information"
			? "bg-primary/20 text-primary"
			: "bg-linear-to-br from-primary to-[#4a0a8b] text-white shadow-lg";

const eyebrowColorClass =
	variant === "success"
		? "text-accent-gold"
		: variant === "information"
			? "text-primary"
			: "text-slate-300";

const bodyColorClass =
	variant === "achievement" ? "text-slate-300 italic" : "text-slate-400";
---

<div
	id={id}
	data-arcane-toast
	data-arcane-toast-id={id}
	data-arcane-toast-duration={duration}
	role="status"
	aria-live="polite"
	aria-atomic="true"
	class:list={[
		floating
			? "fixed left-1/2 top-8 z-[70] w-[min(92vw,30rem)] -translate-x-1/2"
			: "w-full",
		"pointer-events-none -translate-y-4 opacity-0 transition-all duration-500",
		className,
	]}
>
	<div
		class:list={[
			"group relative flex items-stretch gap-4 overflow-hidden rounded-xl border border-l-4 p-4 backdrop-blur-xl",
			cardClass,
		]}
	>
		<div
			class:list={["pointer-events-none absolute inset-0", overlayClass]}
		>
		</div>
		<div
			class:list={[
				"relative flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg",
				iconWrapClass,
			]}
		>
			<span
				class="material-symbols-outlined text-3xl"
				data-arcane-toast-icon>{icon}</span
			>
		</div>
		<div class="relative flex flex-col justify-center gap-1">
			<div class="flex items-center gap-2">
				<span
					class:list={[
						"text-[10px] font-bold uppercase tracking-[0.2em]",
						eyebrowColorClass,
					]}
					data-arcane-toast-eyebrow>{eyebrow}</span
				>
				<div
					class:list={[
						"h-[1px] w-8",
						variant === "success"
							? "bg-accent-gold/30"
							: "bg-primary/30",
					]}
				>
				</div>
			</div>
			<p
				class="text-lg font-bold leading-tight text-slate-100"
				data-arcane-toast-title
			>
				{title}
			</p>
			<p
				class:list={["text-sm leading-normal", bodyColorClass]}
				data-arcane-toast-description
			>
				{description}
			</p>
		</div>
		{
			variant === "achievement" && (
				<div class="absolute bottom-2 right-2">
					<span class="material-symbols-outlined rotate-12 scale-150 text-4xl text-accent-gold/20">
						history_edu
					</span>
				</div>
			)
		}
	</div>
</div>

<script is:inline define:vars={{ toastId: id }}>
	(() => {
		const script = document.currentScript;
		const targetId = toastId;
		const candidate =
			script?.previousElementSibling instanceof HTMLElement
				? script.previousElementSibling
				: null;
		const root =
			candidate && candidate.dataset.arcaneToastId
				? candidate
				: document.getElementById(targetId) ||
					document.querySelector(
						"[data-arcane-toast][data-arcane-toast-id]",
					);

		if (
			!root ||
			!(root instanceof HTMLElement) ||
			root.dataset.ready === "true"
		)
			return;

		const toastIdValue = root.dataset.arcaneToastId || root.id || targetId;
		const defaultDuration = parseInt(
			root.dataset.arcaneToastDuration || "3000",
			10,
		);
		root.dataset.ready = "true";

		const iconEl = root.querySelector("[data-arcane-toast-icon]");
		const eyebrowEl = root.querySelector("[data-arcane-toast-eyebrow]");
		const titleEl = root.querySelector("[data-arcane-toast-title]");
		const descriptionEl = root.querySelector(
			"[data-arcane-toast-description]",
		);

		let timeoutId;

		const hide = () => {
			root.classList.add(
				"pointer-events-none",
				"opacity-0",
				"-translate-y-4",
			);
			root.classList.remove("opacity-100", "translate-y-0");
		};

		const show = (detail = {}) => {
			if (
				typeof detail.icon === "string" &&
				iconEl instanceof HTMLElement
			)
				iconEl.textContent = detail.icon;
			if (
				typeof detail.eyebrow === "string" &&
				eyebrowEl instanceof HTMLElement
			)
				eyebrowEl.textContent = detail.eyebrow;
			if (
				typeof detail.title === "string" &&
				titleEl instanceof HTMLElement
			)
				titleEl.textContent = detail.title;
			if (
				typeof detail.description === "string" &&
				descriptionEl instanceof HTMLElement
			)
				descriptionEl.textContent = detail.description;

			root.classList.remove(
				"pointer-events-none",
				"opacity-0",
				"-translate-y-4",
			);
			root.classList.add("opacity-100", "translate-y-0");

			const wait =
				typeof detail.duration === "number"
					? detail.duration
					: defaultDuration;
			window.clearTimeout(timeoutId);
			timeoutId = window.setTimeout(hide, wait);
		};

		const globalObj = window;
		if (!globalObj.arcaneUI) {
			globalObj.arcaneUI = {};
		}
		if (!globalObj.arcaneUI._toasts) {
			globalObj.arcaneUI._toasts = new Map();
		}
		globalObj.arcaneUI._toasts.set(toastIdValue, { show, hide });
		globalObj.arcaneUI.showToast = (targetId, detail = {}) => {
			const item = globalObj.arcaneUI._toasts.get(targetId);
			if (item) item.show(detail);
		};
		globalObj.arcaneUI.hideToast = (targetId) => {
			const item = globalObj.arcaneUI._toasts.get(targetId);
			if (item) item.hide();
		};

		window.addEventListener("arcane-toast:show", (event) => {
			const detail = event.detail || {};
			if (detail.id && detail.id !== toastIdValue) return;
			show(detail);
		});

		window.addEventListener("arcane-toast:hide", (event) => {
			const detail = event.detail || {};
			if (detail.id && detail.id !== toastIdValue) return;
			hide();
		});
	})();
</script>
