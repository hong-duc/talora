---
interface Props {
	variant?: "default" | "chat";
	className?: string;
	showNav?: boolean;
	activeSection?:
		| "archive"
		| "social"
		| "my-stories"
		| "seekers"
		| "feed"
		| "network";
}

const {
	variant = "default",
	className = "",
	showNav = variant !== "chat",
	activeSection,
} = Astro.props;

const pathname = Astro.url.pathname;
const resolvedActive =
	activeSection ??
	(pathname.startsWith("/archive")
		? "archive"
		: pathname.startsWith("/social/seekers")
			? "seekers"
			: pathname.startsWith("/social")
				? "social"
				: pathname.startsWith("/user/my-stories")
					? "my-stories"
					: pathname.startsWith("/feed")
						? "feed"
						: pathname.match(/^\/user\/[^/]+\/network/)
							? "network"
							: undefined);

const navItemClass = (
	key: "archive" | "social" | "my-stories" | "seekers" | "feed" | "network",
) =>
	`magic-glow flex items-center gap-2 text-base font-medium transition-colors ${
		resolvedActive === key
			? "text-primary"
			: "text-slate-300 hover:text-primary"
	}`;

const headerBgClass =
	variant === "chat" ? "bg-[#191022]/90" : "bg-[#191022]/80";
---

<header
	class:list={[
		"sticky top-0 z-50 border-b border-primary/20 px-6 py-4 backdrop-blur-md lg:px-20",
		headerBgClass,
		className,
	]}
>
	<div class="mx-auto flex max-w-350 items-center justify-between gap-4">
		<div class="flex items-center gap-8">
			<a class="group flex items-center gap-3" href="/">
				<div
					class="flex size-10 items-center justify-center rounded-xl bg-primary/20 text-primary transition-all duration-300 group-hover:bg-primary group-hover:text-white"
				>
					<span class="material-symbols-outlined text-2xl"
						>auto_stories</span
					>
				</div>
				<h1
					class="font-display text-xl font-bold italic leading-tight tracking-tight text-slate-100"
				>
					The Whispering Library
				</h1>
			</a>
			{
				showNav && (
					<nav class="hidden items-center gap-8 md:flex">
						<a class={navItemClass("archive")} href="/archive">
							<span class="material-symbols-outlined text-lg">
								castle
							</span>
							The Great Archive
						</a>
						<a class={navItemClass("social")} href="/social">
							<span class="material-symbols-outlined text-lg">
								forum
							</span>
							Social Space
						</a>
						<a
							class={navItemClass("seekers")}
							href="/social/seekers"
						>
							<span class="material-symbols-outlined text-lg">
								groups
							</span>
							Seekers
						</a>
					</nav>
				)
			}
		</div>
		<div class="flex flex-1 items-center justify-end gap-4 lg:gap-6">
			<div class="hidden flex-1 sm:flex sm:max-w-xs">
				<label class="relative w-full">
					<div
						class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-primary/60"
					>
						<span class="material-symbols-outlined text-xl"
							>search</span
						>
					</div>
					<input
						class="w-full rounded-xl border border-primary/10 bg-primary/5 py-2 pl-10 pr-4 text-sm text-slate-100 outline-none transition-all placeholder:text-slate-400 focus:border-primary focus:ring-2 focus:ring-primary/40"
						placeholder="Seek forbidden knowledge..."
						type="text"
					/>
				</label>
			</div>
			<button
				class="rounded-xl p-2 text-slate-300 transition-colors hover:bg-primary/10 sm:hidden"
				type="button"
			>
				<span class="material-symbols-outlined">search</span>
			</button>
			<div class="relative flex items-center" data-notification-root>
				<button
					aria-controls="header-notification-panel"
					aria-expanded="false"
					aria-haspopup="true"
					class="relative rounded-xl p-2 text-slate-300 transition-colors hover:bg-primary/10"
					data-notification-toggle
					type="button"
				>
					<span class="material-symbols-outlined">notifications</span>
					<span
						class="absolute right-2 top-2 hidden rounded-full border-2 border-[#191022] bg-primary px-0.5 text-[8px] font-bold leading-none text-white"
						data-notif-badge
					></span>
				</button>
				<div
					class="pointer-events-none absolute right-0 top-full z-50 mt-4 w-80 origin-top-right scale-95 overflow-hidden rounded-lg border-2 border-[#d4c5a1] bg-[#f4ecd8] text-slate-900 opacity-0 shadow-2xl transition duration-200"
					data-notification-panel
					id="header-notification-panel"
				>
					<div
						class="flex items-center justify-between border-b border-[#d4c5a1] bg-[#ece2c6] p-4"
					>
						<h3
							class="font-display text-lg font-bold italic text-primary"
						>
							Echoes & Whispers
						</h3>
						<span
							class="material-symbols-outlined text-sm opacity-50"
							>history_edu</span
						>
					</div>
					<div class="max-h-80 overflow-y-auto" data-notif-list>
						<!-- Loading state -->
						<div data-notif-loading class="flex items-center justify-center p-8">
							<div class="animate-pulse flex flex-col items-center gap-3">
								<div class="size-6 rounded-full border-2 border-primary border-t-transparent animate-spin"></div>
								<p class="text-xs text-primary/60 italic">Listening to the whispers...</p>
							</div>
						</div>
						<!-- Empty state (hidden by default) -->
						<div data-notif-empty class="hidden p-8 text-center">
							<span class="material-symbols-outlined text-3xl text-primary/30">inventory_2</span>
							<p class="mt-2 text-sm text-primary/50 italic">No whispers drift on the wind...</p>
						</div>
						<!-- Error state (hidden by default) -->
						<div data-notif-error class="hidden p-8 text-center">
							<span class="material-symbols-outlined text-3xl text-red-400/50">error</span>
							<p class="mt-2 text-sm text-red-400/70 italic">The whispers are silent...</p>
							<button data-notif-retry class="mt-3 text-xs text-primary hover:underline">Try again</button>
						</div>
						<!-- Notification items are rendered here via JS -->
					</div>
					<div
						class="border-t border-[#d4c5a1] bg-[#ece2c6] p-3 text-center"
					>
						<a
							class="text-xs font-bold uppercase tracking-tighter text-primary hover:underline"
							href="/notifications">View all scrolls</a
						>
					</div>
				</div>
			</div>
			<div
				class="flex items-center gap-3 border-l border-primary/10 pl-4"
				data-auth="signed-out"
			>
				<a
					class="inline-flex items-center gap-2 rounded-xl border border-primary/30 bg-primary/20 px-4 py-2 text-sm font-semibold text-primary transition-all hover:border-primary/60 hover:bg-primary/30"
					href="/signin"
				>
					<span class="material-symbols-outlined text-base"
						>login</span
					>
					Sign In
				</a>
			</div>
			<!-- Signed-in: avatar + collapsible "My Space" dropdown -->
			<div
				class="hidden items-center gap-2 border-l border-primary/10 pl-4"
				data-auth="signed-in"
			>
				<!-- My Space dropdown trigger -->
				<div class="relative" data-my-space-root>
					<button
						aria-controls="my-space-panel"
						aria-expanded="false"
						aria-haspopup="true"
						class="flex items-center gap-1 rounded-xl px-3 py-2 text-sm font-medium text-slate-300 transition-colors hover:bg-primary/10 hover:text-primary"
						data-my-space-toggle
						type="button"
					>
						<span class="material-symbols-outlined text-lg"
							>person</span
						>
						<span class="hidden lg:inline">My Space</span>
						<span
							class="material-symbols-outlined text-sm"
							data-my-space-caret>expand_more</span
						>
					</button>
					<div
						class="pointer-events-none absolute right-0 top-full z-50 mt-3 w-52 origin-top-right scale-95 overflow-hidden rounded-xl border border-primary/20 bg-[#1e1030] opacity-0 shadow-2xl transition duration-200"
						data-my-space-panel
						id="my-space-panel"
					>
						<div class="p-2">
							<a
								href="/user/my-stories"
								class={`flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition-colors ${resolvedActive === "my-stories" ? "bg-primary/20 text-primary" : "text-slate-300 hover:bg-primary/10 hover:text-primary"}`}
							>
								<span class="material-symbols-outlined text-lg"
									>auto_stories</span
								>
								My Stories
							</a>
							<a
								href="/feed"
								class={`flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition-colors ${resolvedActive === "feed" ? "bg-primary/20 text-primary" : "text-slate-300 hover:bg-primary/10 hover:text-primary"}`}
							>
								<span class="material-symbols-outlined text-lg"
									>dynamic_feed</span
								>
								Feed
							</a>
							<a
								href="#"
								data-network-link
								class={`flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition-colors ${resolvedActive === "network" ? "bg-primary/20 text-primary" : "text-slate-300 hover:bg-primary/10 hover:text-primary"}`}
							>
								<span class="material-symbols-outlined text-lg"
									>hub</span
								>
								Network
							</a>
						</div>
					</div>
				</div>

				<!-- Avatar -->
				<button class="hidden flex-col items-end lg:flex" type="button">
					<span
						class="text-xs font-semibold uppercase tracking-widest text-primary"
						>Acolyte</span
					>
					<span
						class="text-sm font-medium text-slate-100"
						data-profile-name>Elena Vance</span
					>
				</button>
				<a
					class="group relative cursor-pointer"
					href="/user"
					data-profile-link
				>
					<div
						class="size-10 overflow-hidden rounded-full border-2 border-primary/30 bg-primary/10 p-0.5 transition-all group-hover:border-primary"
					>
						<img
							alt="User Profile"
							class="h-full w-full rounded-full object-cover"
							data-profile-avatar
							src="https://lh3.googleusercontent.com/aida-public/AB6AXuAKqfGt2kbuJ09X81rvdyQQg81Aur4pR04MJUFSDVPOIUGeQ7-GJ-Sj9tmwKsxEZiyyShbYswEbpVUrao70rEmsq4j3doo60DUAH9FNyyEVExWYl6D_JsLe0RdSN7Vxn-1Sz83Pjke0JhToH9IILzgRAbmZxIkL_fwxaa89ERb3Z05dTtyQVPzOLwp4_OSbVzlTAtyYnalEFOUBzNPFUqFy0akr4ik4Y1Xrt8PY9fN2pmA01RkTmMS20xeKUkZe1fSbz4v-PVmDzQ4"
						/>
					</div>
					<div
						class="absolute bottom-0 right-0 size-3 rounded-full border-2 border-[#191022] bg-emerald-500"
					>
					</div>
				</a>
			</div>
		</div>
	</div>
</header>

<script is:inline>
	(() => {
		// ─── Notification action helpers ──────────────────────────────────────
		const ACTION_LABELS = {
			post_like: 'liked your post',
			post_comment: 'commented on your post',
			comment_like: 'liked your comment',
			comment_reply: 'replied to your comment',
			post_repost: 'reposted your post',
			new_follower: 'started following you',
			story_comment: 'commented on your story',
			story_rating: 'rated your story',
		};

		function timeAgo(dateStr) {
			const now = Date.now();
			const then = new Date(dateStr).getTime();
			const diff = now - then;
			const seconds = Math.floor(diff / 1000);
			if (seconds < 60) return 'just now';
			const minutes = Math.floor(seconds / 60);
			if (minutes < 60) return `${minutes}m ago`;
			const hours = Math.floor(minutes / 60);
			if (hours < 24) return `${hours}h ago`;
			const days = Math.floor(hours / 24);
			if (days < 7) return `${days}d ago`;
			const weeks = Math.floor(days / 7);
			if (weeks < 4) return `${weeks}w ago`;
			return new Date(dateStr).toLocaleDateString();
		}

		function getNotifUrl(notif) {
			const postTypes = ['post_like', 'post_comment', 'comment_like', 'comment_reply', 'post_repost'];
			const storyTypes = ['story_comment', 'story_rating'];

			if (postTypes.includes(notif.type) && notif.post_id) {
				return `/social#post-${notif.post_id}`;
			}
			if (storyTypes.includes(notif.type) && notif.story_id) {
				return `/review/${notif.story_id}`;
			}
			if (notif.type === 'new_follower' && notif.actor_id) {
				return `/user/${notif.actor_id}`;
			}
			return '/notifications';
		}

		// ─── Render notifications into a panel ───────────────────────────────
		function renderNotifications(notifListEl, notifications, badgEl) {
			// Remove old notification items (keep loading/empty/error placeholders)
			notifListEl.querySelectorAll('[data-notif-item]').forEach(el => el.remove());

			const loadingEl = notifListEl.querySelector('[data-notif-loading]');
			const emptyEl = notifListEl.querySelector('[data-notif-empty]');
			const errorEl = notifListEl.querySelector('[data-notif-error]');

			if (loadingEl) loadingEl.classList.add('hidden');
			if (errorEl) errorEl.classList.add('hidden');

			if (!notifications || notifications.length === 0) {
				if (emptyEl) emptyEl.classList.remove('hidden');
				if (badgEl) badgEl.classList.add('hidden');
				return;
			}

			if (emptyEl) emptyEl.classList.add('hidden');

			notifications.forEach(function(notif) {
				const btn = document.createElement('button');
				btn.className = 'w-full cursor-pointer border-b border-[#d4c5a1]/50 p-4 text-left transition-colors hover:bg-[#ece2c6]';
				btn.type = 'button';
				btn.setAttribute('data-notif-item', '');
				btn.setAttribute('data-notif-id', notif.id);

				const actorName = notif.actor ? (notif.actor.username || 'Someone') : 'Someone';
				const actionLabel = ACTION_LABELS[notif.type] || notif.type;
				const body = notif.body || '';

				const contentP = document.createElement('p');
				contentP.className = 'font-display text-sm leading-snug';
				const strongEl = document.createElement('strong');
				strongEl.className = 'text-primary font-bold';
				strongEl.textContent = actorName;
				contentP.appendChild(strongEl);
				contentP.appendChild(document.createTextNode(' ' + actionLabel));
				if (body) {
					contentP.appendChild(document.createTextNode(': ' + body));
				}

				const timeP = document.createElement('p');
				timeP.className = 'mt-1 text-[10px] uppercase tracking-widest text-primary/60';
				timeP.textContent = timeAgo(notif.created_at);

				btn.appendChild(contentP);
				btn.appendChild(timeP);

				// Click handler: mark as read + navigate
				btn.addEventListener('click', function(e) {
					e.stopPropagation();
					// Mark as read
					fetch('/api/notifications', {
						method: 'PATCH',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ id: notif.id }),
					}).catch(function() {});
					// Navigate
					const url = getNotifUrl(notif);
					window.location.href = url;
				});

				notifListEl.appendChild(btn);
			});

			// Update badge
			if (badgEl) {
				const unread = notifications.filter(function(n) { return !n.is_read; }).length;
				if (unread > 0) {
					badgEl.classList.remove('hidden');
					badgEl.textContent = unread > 99 ? '99+' : String(unread);
				} else {
					badgEl.classList.add('hidden');
				}
			}
		}

		// ─── Fetch notifications ─────────────────────────────────────────────
		async function loadNotifications(notifListEl, badgEl) {
			const loadingEl = notifListEl.querySelector('[data-notif-loading]');
			const errorEl = notifListEl.querySelector('[data-notif-error]');
			const retryBtn = notifListEl.querySelector('[data-notif-retry]');

			if (loadingEl) loadingEl.classList.remove('hidden');
			if (errorEl) errorEl.classList.add('hidden');

			try {
				const resp = await fetch('/api/notifications?limit=5');
				if (!resp.ok) throw new Error('Failed to fetch');
				const data = await resp.json();
				renderNotifications(notifListEl, data.notifications || [], badgEl);
			} catch (err) {
				if (loadingEl) loadingEl.classList.add('hidden');
				if (errorEl) errorEl.classList.remove('hidden');
				if (retryBtn) {
					retryBtn.onclick = function() {
						loadNotifications(notifListEl, badgEl);
					};
				}
			}
		}

		// ─── Notification panel toggle setup ─────────────────────────────────
		const notifRoots = document.querySelectorAll("[data-notification-root]");
		notifRoots.forEach((root) => {
			if (
				!(root instanceof HTMLElement) ||
				root.dataset.popupReady === "true"
			)
				return;
			root.dataset.popupReady = "true";

			const toggle = root.querySelector("[data-notification-toggle]");
			const panel = root.querySelector("[data-notification-panel]");
			const badgEl = root.querySelector("[data-notif-badge]");
			const notifListEl = root.querySelector("[data-notif-list]");

			if (
				!(toggle instanceof HTMLButtonElement) ||
				!(panel instanceof HTMLElement)
			)
				return;

			let open = false;
			let loaded = false;

			const setOpen = (nextOpen) => {
				open = nextOpen;
				toggle.setAttribute("aria-expanded", String(open));
				panel.classList.toggle("pointer-events-none", !open);
				panel.classList.toggle("opacity-0", !open);
				panel.classList.toggle("scale-95", !open);
				panel.classList.toggle("opacity-100", open);
				panel.classList.toggle("scale-100", open);

				// Fetch notifications when opening for the first time
				if (open && !loaded && notifListEl) {
					loaded = true;
					loadNotifications(notifListEl, badgEl instanceof HTMLElement ? badgEl : null);
				}
			};

			const onDocumentClick = (event) => {
				if (!root.contains(event.target)) setOpen(false);
			};
			const onDocumentKeydown = (event) => {
				if (event.key === "Escape") setOpen(false);
			};

			toggle.addEventListener("click", (event) => {
				event.stopPropagation();
				setOpen(!open);
			});

			document.addEventListener("click", onDocumentClick);
			document.addEventListener("keydown", onDocumentKeydown);
			setOpen(false);

			// Preload notifications on page load
			if (notifListEl) {
				loaded = true;
				loadNotifications(notifListEl, badgEl instanceof HTMLElement ? badgEl : null);
			}
		});

		// My Space dropdown
		const mySpaceRoots = document.querySelectorAll("[data-my-space-root]");
		mySpaceRoots.forEach((root) => {
			if (
				!(root instanceof HTMLElement) ||
				root.dataset.popupReady === "true"
			)
				return;
			root.dataset.popupReady = "true";

			const toggle = root.querySelector("[data-my-space-toggle]");
			const panel = root.querySelector("[data-my-space-panel]");
			const caret = root.querySelector("[data-my-space-caret]");

			if (
				!(toggle instanceof HTMLButtonElement) ||
				!(panel instanceof HTMLElement)
			)
				return;

			let open = false;

			const setOpen = (nextOpen) => {
				open = nextOpen;
				toggle.setAttribute("aria-expanded", String(open));
				panel.classList.toggle("pointer-events-none", !open);
				panel.classList.toggle("opacity-0", !open);
				panel.classList.toggle("scale-95", !open);
				panel.classList.toggle("opacity-100", open);
				panel.classList.toggle("scale-100", open);
				if (caret instanceof HTMLElement) {
					caret.textContent = open ? "expand_less" : "expand_more";
				}
			};

			const onDocumentClick = (event) => {
				if (!root.contains(event.target)) setOpen(false);
			};
			const onDocumentKeydown = (event) => {
				if (event.key === "Escape") setOpen(false);
			};

			toggle.addEventListener("click", (event) => {
				event.stopPropagation();
				setOpen(!open);
			});

			document.addEventListener("click", onDocumentClick);
			document.addEventListener("keydown", onDocumentKeydown);
			setOpen(false);
		});
	})();
</script>

<script>
	import "../scripts/profile-sync";
</script>

<style>
	.magic-glow:hover {
		text-shadow: 0 0 8px rgb(115 17 212 / 60%);
	}
</style>