---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

// Import our new TestToast component that handles all interactive functionality
import TestToast from "../components/TestToast.svelte";
---

<html class="dark" lang="en">
    <head>
        <meta charset="utf-8" />
        <meta content="width=device-width, initial-scale=1.0" name="viewport" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>Toast Components Test - The Whispering Library</title>
        <link
            href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,200..800&display=swap"
            rel="stylesheet"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
            rel="stylesheet"
        />
    </head>
    <body class="bg-background-dark text-slate-100 selection:bg-primary/30">
        <div
            class="relative flex h-auto min-h-screen w-full flex-col overflow-x-hidden"
        >
            <div class="layout-container flex h-full grow flex-col">
                <SiteHeader />

                <main class="mx-auto w-full max-w-6xl px-4 py-8 lg:px-8">
                    {/* Page Header */}
                    <div class="mb-12 text-center">
                        <h1
                            class="font-display text-5xl font-bold leading-tight text-slate-100 md:text-6xl"
                        >
                            Toast Components <span class="gold-shimmer"
                                >Test Page</span
                            >
                        </h1>
                        <p
                            class="mx-auto mt-4 max-w-2xl text-lg text-slate-400"
                        >
                            Test the custom Success and Error toast components
                            integrated with svelte-sonner. Each toast uses the
                            project's arcane design system with Tailwind CSS.
                        </p>
                        <div
                            class="mt-6 inline-flex items-center gap-2 rounded-full bg-primary/10 px-4 py-2 text-sm font-medium text-primary"
                        >
                            <span class="material-symbols-outlined text-base"
                                >notifications</span
                            >
                            Route: /test
                        </div>
                    </div>

                    {/* Interactive Toast Testing */}
                    <TestToast client:load />

                    {/* svelte-sonner Configuration Info */}
                    <section
                        class="rounded-2xl border border-primary/20 bg-linear-to-br from-slate-900/50 to-slate-900/30 p-6 shadow-xl mt-12"
                    >
                        <h2
                            class="font-display text-3xl font-bold text-slate-100 mb-6"
                        >
                            svelte-sonner Configuration
                        </h2>

                        <div class="grid gap-8 md:grid-cols-2">
                            <div class="space-y-6">
                                <h3
                                    class="text-xl font-semibold text-slate-300"
                                >
                                    Toast Options
                                </h3>
                                <div class="space-y-4">
                                    <div class="rounded-lg bg-slate-900/50 p-4">
                                        <h4
                                            class="mb-2 font-semibold text-slate-300"
                                        >
                                            Duration
                                        </h4>
                                        <p class="text-slate-400">
                                            Default: 5000ms (5 seconds)
                                        </p>
                                        <p class="mt-2 text-sm text-slate-500">
                                            Configurable via svelte-sonner
                                            options
                                        </p>
                                    </div>
                                    <div class="rounded-lg bg-slate-900/50 p-4">
                                        <h4
                                            class="mb-2 font-semibold text-slate-300"
                                        >
                                            Position
                                        </h4>
                                        <p class="text-slate-400">
                                            Top-center (default)
                                        </p>
                                        <p class="mt-2 text-sm text-slate-500">
                                            Can be changed via Toaster component
                                            props
                                        </p>
                                    </div>
                                    <div class="rounded-lg bg-slate-900/50 p-4">
                                        <h4
                                            class="mb-2 font-semibold text-slate-300"
                                        >
                                            Animation
                                        </h4>
                                        <p class="text-slate-400">
                                            Built-in entrance/exit animations
                                        </p>
                                        <p class="mt-2 text-sm text-slate-500">
                                            svelte-sonner handles slide-in and
                                            fade-out effects
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <div class="space-y-6">
                                <h3
                                    class="text-xl font-semibold text-slate-300"
                                >
                                    Integration Notes
                                </h3>
                                <div class="rounded-lg bg-slate-900/50 p-4">
                                    <h4
                                        class="mb-2 font-semibold text-slate-300"
                                    >
                                        Component Architecture
                                    </h4>
                                    <p class="text-slate-400">
                                        The TestToast.svelte component
                                        demonstrates the simplified Svelte
                                        pattern for using svelte-sonner. Unlike
                                        the complex event bridge previously
                                        needed for Astro pages, Svelte
                                        components can import and use
                                        svelte-sonner directly.
                                    </p>
                                </div>
                                <div class="rounded-lg bg-slate-900/50 p-4">
                                    <h4
                                        class="mb-2 font-semibold text-slate-300"
                                    >
                                        Close Integration
                                    </h4>
                                    <p class="text-slate-400">
                                        The close button in each toast component
                                        calls svelte-sonner's dismiss function
                                        when clicked.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </section>
                </main>

                <SiteFooter />
            </div>
        </div>
    </body>
</html>
