---
export const prerender = true;

import "../styles/global.css";
---

<html class="dark" lang="en">
    <head>
        <meta charset="utf-8" />
        <meta content="width=device-width, initial-scale=1.0" name="viewport" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>The Whispering Library - Request a Seal</title>
        <link
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
            rel="stylesheet"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,200..800&display=swap"
            rel="stylesheet"
        />
    </head>
    <body class="min-h-screen bg-background-dark font-display text-slate-100">
        <div
            class="relative flex h-auto min-h-screen w-full flex-col overflow-x-hidden bg-background-dark"
        >
            <div class="layout-container flex h-full grow flex-col">
                <div
                    class="flex flex-1 justify-center py-10 px-4 md:px-10 lg:px-40"
                >
                    <div
                        class="layout-content-container flex flex-col max-w-[960px] flex-1"
                    >
                        <div class="@container">
                            <div class="@[480px]:px-4 @[480px]:py-3">
                                <div
                                    class="w-full bg-center bg-no-repeat bg-cover flex flex-col justify-end overflow-hidden rounded-xl border border-primary/20 min-h-[320px] shadow-2xl shadow-primary/10"
                                    style='background-image: url("/registion.png");'
                                >
                                </div>
                            </div>
                        </div>
                        <div
                            class="flex flex-wrap justify-between gap-3 p-4 mt-6"
                        >
                            <div class="flex min-w-72 flex-col gap-2">
                                <h1
                                    class="text-slate-100 text-4xl font-black leading-tight tracking-[-0.033em]"
                                >
                                    Request a Seal
                                </h1>
                                <p
                                    class="text-primary dark:text-primary/70 text-lg font-medium leading-normal"
                                >
                                    Join the seekers of ancient knowledge at The
                                    Whispering Library
                                </p>
                            </div>
                        </div>
                        <form
                            id="registration-form"
                            class="flex flex-col gap-2"
                        >
                            <div
                                class="grid grid-cols-1 md:grid-cols-2 gap-4 px-4 py-3"
                            >
                                <label class="flex flex-col min-w-40 flex-1">
                                    <p
                                        class="text-slate-100 text-base font-medium leading-normal pb-2"
                                    >
                                        Seeker Alias
                                    </p>
                                    <input
                                        id="alias"
                                        name="alias"
                                        class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-xl text-slate-100 focus:outline-0 focus:ring-2 focus:ring-primary border border-primary/20 bg-background-dark/50 focus:border-primary h-14 placeholder:text-slate-400 dark:placeholder:text-primary/40 p-[15px] text-base font-normal leading-normal transition-all"
                                        placeholder="Enter your moniker"
                                        type="text"
                                        required
                                        maxlength="50"
                                    />
                                </label>
                                <label class="flex flex-col min-w-40 flex-1">
                                    <p
                                        class="text-slate-100 text-base font-medium leading-normal pb-2"
                                    >
                                        Mystic Email
                                    </p>
                                    <input
                                        id="email"
                                        name="email"
                                        class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-xl text-slate-100 focus:outline-0 focus:ring-2 focus:ring-primary border border-primary/20 bg-background-dark/50 focus:border-primary h-14 placeholder:text-slate-400 dark:placeholder:text-primary/40 p-[15px] text-base font-normal leading-normal transition-all"
                                        placeholder="oracle@library.com"
                                        type="email"
                                        required
                                    />
                                </label>
                            </div>
                            <div
                                class="grid grid-cols-1 md:grid-cols-2 gap-4 px-4 py-3"
                            >
                                <label class="flex flex-col min-w-40 flex-1">
                                    <p
                                        class="text-slate-100 text-base font-medium leading-normal pb-2"
                                    >
                                        Secret Incantation
                                    </p>
                                    <div
                                        class="flex w-full flex-1 items-stretch rounded-xl"
                                    >
                                        <input
                                            id="password"
                                            name="password"
                                            class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-xl text-slate-100 focus:outline-0 focus:ring-2 focus:ring-primary border border-primary/20 bg-background-dark/50 focus:border-primary h-14 placeholder:text-slate-400 dark:placeholder:text-primary/40 p-[15px] rounded-r-none border-r-0 pr-2 text-base font-normal leading-normal transition-all"
                                            placeholder="••••••••"
                                            type="password"
                                            required
                                            minlength="8"
                                        />
                                        <button
                                            type="button"
                                            id="toggle-password"
                                            class="text-primary/60 flex border border-primary/20 bg-background-dark/50 items-center justify-center pr-[15px] rounded-r-xl border-l-0 hover:text-primary transition-colors"
                                        >
                                            <span
                                                class="material-symbols-outlined"
                                                >visibility</span
                                            >
                                        </button>
                                    </div>
                                </label>
                                <label class="flex flex-col min-w-40 flex-1">
                                    <p
                                        class="text-slate-100 text-base font-medium leading-normal pb-2"
                                    >
                                        Confirm Incantation
                                    </p>
                                    <div
                                        class="flex w-full flex-1 items-stretch rounded-xl"
                                    >
                                        <input
                                            id="confirm-password"
                                            name="confirm-password"
                                            class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-xl text-slate-100 focus:outline-0 focus:ring-2 focus:ring-primary border border-primary/20 bg-background-dark/50 focus:border-primary h-14 placeholder:text-slate-400 dark:placeholder:text-primary/40 p-[15px] rounded-r-none border-r-0 pr-2 text-base font-normal leading-normal transition-all"
                                            placeholder="••••••••"
                                            type="password"
                                            required
                                            minlength="8"
                                        />
                                        <button
                                            type="button"
                                            id="toggle-confirm-password"
                                            class="text-primary/60 flex border border-primary/20 bg-background-dark/50 items-center justify-center pr-[15px] rounded-r-xl border-l-0 hover:text-primary transition-colors"
                                        >
                                            <span
                                                class="material-symbols-outlined"
                                                >visibility</span
                                            >
                                        </button>
                                    </div>
                                </label>
                            </div>
                            <div id="error-message" class="hidden px-4 py-3">
                                <div
                                    class="rounded-xl border border-red-500/30 bg-red-500/10 p-4 text-red-400"
                                >
                                    <p id="error-text"></p>
                                </div>
                            </div>
                            <div class="px-4 py-6">
                                <button
                                    id="submit-btn"
                                    type="submit"
                                    class="w-full h-14 bg-primary hover:bg-primary/90 text-white font-bold text-lg rounded-xl transition-all shadow-lg shadow-primary/25 flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed"
                                >
                                    <span class="material-symbols-outlined"
                                        >auto_fix_high</span
                                    >
                                    Invoke Membership
                                </button>
                            </div>
                        </form>
                        <div class="px-4 py-2 flex items-center gap-4">
                            <div class="h-px bg-primary/20 flex-1"></div>
                            <p
                                class="text-primary/60 text-sm font-medium uppercase tracking-widest"
                            >
                                Or Bind Via
                            </p>
                            <div class="h-px bg-primary/20 flex-1"></div>
                        </div>
                        <div
                            class="grid grid-cols-1 md:grid-cols-2 gap-4 px-4 py-4"
                        >
                            <button
                                class="flex items-center justify-center gap-3 h-14 rounded-xl border border-primary/20 bg-background-dark/30 hover:bg-primary/5 transition-colors text-slate-100 font-medium"
                            >
                                <svg class="w-5 h-5" viewBox="0 0 24 24">
                                    <path
                                        d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                                        fill="currentColor"></path>
                                    <path
                                        d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                                        fill="currentColor"></path>
                                    <path
                                        d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"
                                        fill="currentColor"></path>
                                    <path
                                        d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                                        fill="currentColor"></path>
                                </svg>
                                Bind with Google
                            </button>
                            <button
                                class="flex items-center justify-center gap-3 h-14 rounded-xl border border-primary/20 bg-background-dark/30 hover:bg-primary/5 transition-colors text-slate-100 font-medium"
                            >
                                <svg class="w-6 h-6" viewBox="0 0 24 24">
                                    <path
                                        d="M19.27 4.73C17.78 3.35 15.83 2.5 13.73 2.5c-4.54 0-8.23 3.69-8.23 8.23 0 2.1.79 4.02 2.08 5.5l-2.08 4.77 4.77-2.08c1.48 1.29 3.4 2.08 5.5 2.08 4.54 0 8.23-3.69 8.23-8.23 0-2.1-.85-4.05-2.23-5.54zM13.73 17.5c-3.72 0-6.73-3.01-6.73-6.73s3.01-6.73 6.73-6.73 6.73 3.01 6.73 6.73-3.01 6.73-6.73 6.73z"
                                        fill="currentColor"></path>
                                </svg>
                                Echo with Discord
                            </button>
                        </div>
                        <div class="px-4 py-8 text-center">
                            <p class="text-slate-400 text-base">
                                Already a keeper of secrets?
                                <a
                                    class="text-primary font-bold hover:underline decoration-primary/30 underline-offset-4 ml-1"
                                    href="/signin">Recall Access</a
                                >
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <script>
            import { signUp } from "../lib/auth";

            const form = document.getElementById(
                "registration-form",
            ) as HTMLFormElement;
            const submitBtn = document.getElementById(
                "submit-btn",
            ) as HTMLButtonElement;
            const errorMessage = document.getElementById(
                "error-message",
            ) as HTMLDivElement;
            const errorText = document.getElementById(
                "error-text",
            ) as HTMLParagraphElement;
            const passwordInput = document.getElementById(
                "password",
            ) as HTMLInputElement;
            const confirmPasswordInput = document.getElementById(
                "confirm-password",
            ) as HTMLInputElement;
            const togglePasswordBtn = document.getElementById(
                "toggle-password",
            ) as HTMLButtonElement;
            const toggleConfirmPasswordBtn = document.getElementById(
                "toggle-confirm-password",
            ) as HTMLButtonElement;

            // Password visibility toggle
            function togglePasswordVisibility(
                input: HTMLInputElement,
                button: HTMLButtonElement,
            ) {
                const icon = button.querySelector(".material-symbols-outlined");
                if (input.type === "password") {
                    input.type = "text";
                    if (icon) icon.textContent = "visibility_off";
                } else {
                    input.type = "password";
                    if (icon) icon.textContent = "visibility";
                }
            }

            togglePasswordBtn?.addEventListener("click", () => {
                togglePasswordVisibility(passwordInput, togglePasswordBtn);
            });

            toggleConfirmPasswordBtn?.addEventListener("click", () => {
                togglePasswordVisibility(
                    confirmPasswordInput,
                    toggleConfirmPasswordBtn,
                );
            });

            // Form submission
            form?.addEventListener("submit", async (e) => {
                e.preventDefault();

                const alias = (
                    document.getElementById("alias") as HTMLInputElement
                ).value.trim();
                const email = (
                    document.getElementById("email") as HTMLInputElement
                ).value.trim();
                const password = passwordInput.value;
                const confirmPassword = confirmPasswordInput.value;

                // Hide previous error
                errorMessage.classList.add("hidden");

                // Validate passwords match
                if (password !== confirmPassword) {
                    errorText.textContent =
                        "Secret incantations do not match. Please try again.";
                    errorMessage.classList.remove("hidden");
                    return;
                }

                // Validate alias length
                if (alias.length < 2) {
                    errorText.textContent =
                        "Seeker Alias must be at least 2 characters.";
                    errorMessage.classList.remove("hidden");
                    return;
                }

                // Disable button and show loading state
                submitBtn.disabled = true;
                submitBtn.innerHTML =
                    '<span class="material-symbols-outlined animate-spin">progress_activity</span> Invoking...';

                try {
                    // Step 1: Sign up the user
                    const { error: signUpError } = await signUp(
                        email,
                        password,
                        alias,
                    );

                    if (signUpError) {
                        throw new Error(signUpError.message);
                    }

                    // Success - redirect to archive
                    window.location.href = "/archive";
                } catch (err) {
                    const errorMsg =
                        err instanceof Error
                            ? err.message
                            : "An unknown error occurred. Please try again.";
                    errorText.textContent = errorMsg;
                    errorMessage.classList.remove("hidden");
                    submitBtn.disabled = false;
                    submitBtn.innerHTML =
                        '<span class="material-symbols-outlined">auto_fix_high</span> Invoke Membership';
                }
            });
        </script>
    </body>
</html>
