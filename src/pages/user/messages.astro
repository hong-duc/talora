---
import '../../styles/global.css';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import LibrarySectionNav from '../../components/LibrarySectionNav.astro';
import { messageThreads } from '../../messages-content';
---

<html class="dark" lang="en">
	<head>
		<meta charset="utf-8" />
		<meta content="width=device-width, initial-scale=1.0" name="viewport" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Scroll of Whispers - The Whispering Library</title>
		<link
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
			rel="stylesheet"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="min-h-screen bg-background-dark font-display text-slate-100">
		<div class="relative flex min-h-screen w-full flex-col overflow-x-hidden bg-background-dark">
			<SiteHeader />

			<div class="mx-auto w-full max-w-6xl px-6 pt-6 lg:px-20">
				<LibrarySectionNav active="my-messages" />
			</div>

			<main class="mx-auto flex w-full max-w-[1600px] flex-1 flex-col gap-6 px-4 py-8 lg:px-20">
				<div class="grid grid-cols-1 gap-6 lg:grid-cols-[260px_1fr]">
					<aside class="hidden flex-col gap-6 lg:flex">
						<div class="space-y-1 rounded-xl border border-primary/10 bg-primary/5 p-4">
							<p class="mb-2 px-3 text-xs font-bold uppercase tracking-widest text-primary/60">Navigation</p>
							<a class="flex items-center gap-3 rounded-xl bg-primary px-3 py-2.5 text-white shadow-lg shadow-primary/20" href="#">
								<span class="material-symbols-outlined">inbox</span>
								<span class="font-medium">Inbox</span>
								<span class="ml-auto rounded-full bg-white/20 px-2 py-0.5 text-xs">{messageThreads.length}</span>
							</a>
							<a class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-slate-300 transition-colors hover:bg-primary/10" href="#">
								<span class="material-symbols-outlined text-[#d4af37]">star</span>
								<span class="font-medium">Important</span>
							</a>
							<a class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-slate-300 transition-colors hover:bg-primary/10" href="#">
								<span class="material-symbols-outlined">send</span>
								<span class="font-medium">Sent Whispers</span>
							</a>
							<a class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-slate-300 transition-colors hover:bg-primary/10" href="#">
								<span class="material-symbols-outlined">archive</span>
								<span class="font-medium">Archive</span>
							</a>
						</div>
						<div class="mt-auto rounded-2xl border border-primary/20 bg-linear-to-br from-primary/20 to-transparent p-4">
							<p class="mb-2 italic leading-relaxed text-primary">"The library holds secrets that only the silent can hear."</p>
							<p class="text-[10px] uppercase tracking-tighter text-slate-500">- Ancient Proverb</p>
						</div>
					</aside>

					<section class="min-w-0 rounded-xl border border-primary/10 bg-background-dark/50 p-4 md:p-6">
						<div class="mb-6 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
							<div>
								<h1 class="text-4xl font-bold tracking-tight">Scroll of Whispers</h1>
								<p class="mt-1 text-slate-400">Correspondence from the mystical realms and fellow seekers.</p>
							</div>
							<div class="flex gap-2">
								<button class="flex items-center gap-2 rounded-xl bg-primary/10 px-4 py-2 text-sm font-bold text-primary transition-all hover:bg-primary/20" type="button">
									<span class="material-symbols-outlined text-lg">filter_list</span>
									Filter
								</button>
								<a class="flex items-center gap-2 rounded-xl bg-primary px-6 py-2 text-sm font-bold text-white shadow-lg shadow-primary/30 transition-all hover:opacity-90" href="/user/messages/compose">
									<span class="material-symbols-outlined text-lg">edit</span>
									New Whisper
								</a>
							</div>
						</div>

						<div class="custom-scrollbar max-h-[65vh] space-y-3 overflow-y-auto pr-1">
							{
								messageThreads.map((thread) => (
									<a
										href={`/user/messages/${thread.id}`}
										class={`group relative flex cursor-pointer items-center gap-4 rounded-2xl border bg-primary/5 p-4 transition-all hover:border-primary/40 ${thread.important ? 'important-glow border-primary/10' : 'border-primary/10'}`}
									>
										{thread.important && (
											<div class="absolute left-0 top-1/2 h-12 w-1 -translate-y-1/2 rounded-r-full bg-[#d4af37] shadow-[0_0_10px_#d4af37]"></div>
										)}
										<div class="relative shrink-0">
											<div class={`size-14 overflow-hidden rounded-full border-2 ${thread.important ? 'border-[#d4af37]/50' : 'border-primary/20'}`}>
												<img class="h-full w-full object-cover" src={thread.avatar} alt={thread.sender} />
											</div>
											{thread.important && (
												<div class="absolute -bottom-1 -right-1 rounded-full border-2 border-background-dark bg-[#d4af37] p-0.5 text-white">
													<span class="material-symbols-outlined block text-xs font-bold">star</span>
												</div>
											)}
										</div>
										<div class="min-w-0 flex-1">
											<div class="mb-1 flex items-center justify-between">
												<h3 class="font-display text-lg font-bold">{thread.sender}</h3>
												<span class="text-xs text-slate-500">{thread.listTime}</span>
											</div>
											{thread.subject && <p class="mb-1 text-sm font-semibold text-primary">{thread.subject}</p>}
											<p class="truncate text-sm leading-relaxed text-slate-400">{thread.preview}</p>
										</div>
									</a>
								))
							}
						</div>

						<div class="mt-8 flex justify-center">
							<button class="flex items-center gap-2 rounded-xl border border-primary/20 px-4 py-2 text-sm font-bold text-primary transition-all hover:bg-primary/5 hover:text-primary/70" type="button">
								<span class="material-symbols-outlined">expand_more</span>
								Reveal Older Whispers
							</button>
						</div>
					</section>
				</div>
			</main>

			<SiteFooter />
		</div>
	</body>
</html>

<style>
	.custom-scrollbar::-webkit-scrollbar {
		width: 4px;
	}

	.custom-scrollbar::-webkit-scrollbar-track {
		background: transparent;
	}

	.custom-scrollbar::-webkit-scrollbar-thumb {
		background: rgb(115 17 212 / 27%);
		border-radius: 10px;
	}

	.important-glow {
		box-shadow: 0 0 15px rgb(212 175 55 / 15%);
	}
</style>
