---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import LibrarySectionNav from '../components/LibrarySectionNav.astro';
---

<html class="dark" lang="en">
	<head>
		<meta charset="utf-8" />
		<meta content="width=device-width, initial-scale=1.0" name="viewport" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Scrying Results - The Whispering Library</title>
		<link
			href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&display=swap"
			rel="stylesheet"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="min-h-screen bg-background-dark font-display text-slate-100">
		<div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">
			<SiteHeader />

			<div class="mx-auto w-full max-w-6xl px-6 pt-6 lg:px-20">
				<LibrarySectionNav active="search" />
			</div>

			<main class="mx-auto flex w-full max-w-[1440px] flex-1 flex-col gap-10 px-6 py-10 md:flex-row lg:px-20">
				<aside class="w-full md:w-64">
					<div class="flex flex-col gap-6 rounded-xl border border-primary/10 bg-primary/5 p-6">
						<div>
							<h1 class="text-lg font-bold">Essence Filters</h1>
							<p class="text-sm italic text-slate-400">Refine your scrying</p>
						</div>
						<div class="flex flex-col gap-4">
							<button class="flex w-full items-center justify-between rounded-lg bg-primary px-4 py-3 text-white shadow-lg shadow-primary/20">
								<span class="flex items-center gap-3 text-sm font-medium">
									<span class="material-symbols-outlined text-xl">storm</span>
									Genre
								</span>
								<span class="material-symbols-outlined">expand_more</span>
							</button>
							<button class="flex w-full items-center justify-between rounded-lg border border-primary/10 bg-slate-900/40 px-4 py-3 transition-all hover:border-primary/40">
								<span class="flex items-center gap-3 text-sm font-medium">
									<span class="material-symbols-outlined text-xl text-primary">diamond</span>
									Rarity
								</span>
								<span class="material-symbols-outlined text-slate-400">chevron_right</span>
							</button>
							<button class="flex w-full items-center justify-between rounded-lg border border-primary/10 bg-slate-900/40 px-4 py-3 transition-all hover:border-primary/40">
								<span class="flex items-center gap-3 text-sm font-medium">
									<span class="material-symbols-outlined text-xl text-primary">hourglass_empty</span>
									Date Added
								</span>
								<span class="material-symbols-outlined text-slate-400">chevron_right</span>
							</button>
						</div>
						<div class="border-t border-primary/10 pt-4">
							<p class="mb-3 text-xs uppercase tracking-tighter text-slate-400">Popular Tags</p>
							<div class="flex flex-wrap gap-2">
								<span class="rounded bg-primary/10 px-2 py-1 text-xs font-medium text-primary">Ethereal</span>
								<span class="rounded bg-primary/10 px-2 py-1 text-xs font-medium text-primary">Forbidden</span>
								<span class="rounded bg-primary/10 px-2 py-1 text-xs font-medium text-primary">Old Gods</span>
							</div>
						</div>
					</div>
				</aside>

				<div class="flex min-w-0 flex-1 flex-col gap-10">
					<div class="flex flex-col gap-6">
						<div class="group relative">
							<div class="absolute -inset-1 rounded-xl bg-gradient-to-r from-primary to-purple-400 opacity-25 blur transition duration-1000 group-focus-within:opacity-50 group-hover:duration-200"></div>
							<label class="relative flex h-16 w-full items-center overflow-hidden rounded-xl border border-primary/30 bg-slate-900 px-4">
								<span class="material-symbols-outlined px-2 text-2xl text-primary">magic_button</span>
								<input
									class="w-full border-none bg-transparent text-lg italic placeholder:text-slate-500 focus:ring-0"
									placeholder="Scry for more 'The Whispering Library'..."
									value="The Whispering Library"
								/>
								<button class="rounded-lg bg-primary px-6 py-2 font-medium text-white transition-all hover:bg-primary/90">Invoke</button>
							</label>
						</div>
						<div class="flex flex-wrap items-end justify-between gap-3">
							<div class="flex flex-col gap-1">
								<h2 class="text-4xl font-black tracking-tight">Scrying Results</h2>
								<p class="text-base italic text-slate-400">Discoveries from the ethereal depths for your query</p>
							</div>
							<p class="rounded-full border border-primary/20 bg-primary/10 px-3 py-1 text-sm font-medium text-primary">42 Emanations Found</p>
						</div>
					</div>

					<section class="flex flex-col gap-6">
						<div class="flex items-center gap-4">
							<h3 class="text-2xl font-bold">Tales &amp; Tomes</h3>
							<div class="h-px flex-1 bg-gradient-to-r from-primary/30 to-transparent"></div>
						</div>
						<div class="grid grid-cols-1 gap-6 md:grid-cols-2">
							<article class="group relative overflow-hidden rounded-xl border border-primary/10 bg-slate-900/40 p-1 transition-all duration-300 hover:border-primary/50">
								<div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-primary/5 via-transparent to-transparent"></div>
								<div class="relative flex gap-4 p-4">
									<div class="h-32 w-24 flex-shrink-0 overflow-hidden rounded-lg border border-primary/30 bg-primary/20 shadow-inner transition-transform group-hover:scale-105">
										<div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-primary/40 to-background-dark">
											<span class="material-symbols-outlined text-4xl text-primary/60">menu_book</span>
										</div>
									</div>
									<div class="flex flex-col justify-between py-1">
										<div>
											<div class="mb-1 flex items-center gap-2">
												<span class="rounded bg-primary/20 px-2 py-0.5 text-[10px] uppercase tracking-widest text-primary">Legendary</span>
												<span class="text-xs italic text-slate-500">Added 3 moons ago</span>
											</div>
											<h4 class="text-lg font-bold transition-colors group-hover:text-primary">The Silence Between Pages</h4>
											<p class="line-clamp-2 text-sm italic text-slate-400">A record of every word unsaid within the library's walls, bound in shadow-silk...</p>
										</div>
										<div class="flex items-center gap-3 text-xs font-medium text-slate-400">
											<span class="flex items-center gap-1"><span class="material-symbols-outlined text-sm">visibility</span> 1.2k</span>
											<span class="flex items-center gap-1"><span class="material-symbols-outlined text-sm">auto_fix</span> 84</span>
										</div>
									</div>
								</div>
							</article>

							<article class="group relative overflow-hidden rounded-xl border border-primary/10 bg-slate-900/40 p-1 transition-all duration-300 hover:border-primary/50">
								<div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-primary/5 via-transparent to-transparent"></div>
								<div class="relative flex gap-4 p-4">
									<div class="h-32 w-24 flex-shrink-0 overflow-hidden rounded-lg border border-primary/30 bg-primary/20 shadow-inner transition-transform group-hover:scale-105">
										<div class="flex h-full w-full items-center justify-center bg-gradient-to-tr from-indigo-900 to-primary/30">
											<span class="material-symbols-outlined text-4xl text-primary/60">history_edu</span>
										</div>
									</div>
									<div class="flex flex-col justify-between py-1">
										<div>
											<div class="mb-1 flex items-center gap-2">
												<span class="rounded bg-slate-500/20 px-2 py-0.5 text-[10px] uppercase tracking-widest text-slate-400">Rare</span>
												<span class="text-xs italic text-slate-500">Added 1 moon ago</span>
											</div>
											<h4 class="text-lg font-bold transition-colors group-hover:text-primary">Echoes of the First Librarian</h4>
											<p class="line-clamp-2 text-sm italic text-slate-400">Transcribed whispers heard in the North Wing during the Great Eclipse...</p>
										</div>
										<div class="flex items-center gap-3 text-xs font-medium text-slate-400">
											<span class="flex items-center gap-1"><span class="material-symbols-outlined text-sm">visibility</span> 856</span>
											<span class="flex items-center gap-1"><span class="material-symbols-outlined text-sm">auto_fix</span> 32</span>
										</div>
									</div>
								</div>
							</article>
						</div>
					</section>

					<section class="flex flex-col gap-6">
						<div class="flex items-center gap-4">
							<h3 class="text-2xl font-bold">Seekers &amp; Spirits</h3>
							<div class="h-px flex-1 bg-gradient-to-r from-primary/30 to-transparent"></div>
						</div>
						<div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
							<div class="flex items-center gap-4 rounded-xl border border-primary/10 bg-primary/5 p-4 transition-colors hover:bg-primary/10">
								<div class="size-14 overflow-hidden rounded-full border-2 border-primary bg-primary/20">
									<div class="h-full w-full bg-gradient-to-b from-primary/50 to-transparent"></div>
								</div>
								<div>
									<h5 class="font-bold">Elder Thorne</h5>
									<p class="text-xs font-medium italic text-primary">Keeper of Lost Names</p>
									<p class="mt-1 text-[10px] text-slate-500">Found in Vault Section 7G</p>
								</div>
							</div>
							<div class="flex items-center gap-4 rounded-xl border border-primary/10 bg-primary/5 p-4 transition-colors hover:bg-primary/10">
								<div class="size-14 overflow-hidden rounded-full border-2 border-primary/40 bg-primary/20">
									<div class="h-full w-full bg-gradient-to-tr from-indigo-500/40 to-transparent"></div>
								</div>
								<div>
									<h5 class="font-bold">Aria the Weaver</h5>
									<p class="text-xs font-medium italic text-primary">Scryer Grade III</p>
									<p class="mt-1 text-[10px] text-slate-500">Active in Current Thread</p>
								</div>
							</div>
							<div class="flex items-center gap-4 rounded-xl border border-primary/10 bg-primary/5 p-4 transition-colors hover:bg-primary/10">
								<div class="size-14 overflow-hidden rounded-full border-2 border-primary/40 bg-primary/20">
									<div class="h-full w-full bg-gradient-to-br from-purple-500/40 to-transparent"></div>
								</div>
								<div>
									<h5 class="font-bold">The Ink-Stained</h5>
									<p class="text-xs font-medium italic text-primary">Spectral Scribe</p>
									<p class="mt-1 text-[10px] text-slate-500">Found in Drafting Chambers</p>
								</div>
							</div>
						</div>
					</section>

					<div class="flex justify-center py-10">
						<button class="group flex items-center gap-2 rounded-xl border border-primary/30 bg-primary/5 px-8 py-3 font-bold text-primary transition-all duration-300 hover:bg-primary hover:text-white">
							<span>Summon more results</span>
							<span class="material-symbols-outlined transition-transform group-hover:rotate-180">cyclone</span>
						</button>
					</div>
				</div>
			</main>

			<SiteFooter />
		</div>
	</body>
</html>
