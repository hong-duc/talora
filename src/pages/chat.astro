---
/**
 * /chat
 *
 * SSR wrapper for the chat experience.
 * Reads ?session=<uuid> from the URL and passes it to ChatPage (client:load).
 * All data fetching (auth, sidebar sessions, messages) happens client-side
 * because the Supabase access token lives in browser localStorage.
 */
export const prerender = false;
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import ChatPage from "../components/ChatPage.svelte";

// Read optional session ID from URL search params
const sessionId = Astro.url.searchParams.get("session");
---

<html class="dark" lang="en">
	<head>
		<meta charset="utf-8" />
		<meta content="width=device-width, initial-scale=1.0" name="viewport" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>The Whispering Library — Chat</title>
		<link
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
			rel="stylesheet"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&display=swap"
			rel="stylesheet"
		/>
		<!-- Extra free reading fonts for the chat font picker -->
		<link
			href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..700&family=Merriweather:ital,wght@0,300;0,400;0,700;1,300;1,400;1,700&family=Literata:ital,opsz,wght@0,7..72,200..900;1,7..72,200..900&family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400;1,700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body
		class="h-screen overflow-hidden bg-background-dark font-display text-slate-100"
	>
		<div
			class="relative flex h-screen w-full flex-col overflow-hidden bg-background-dark"
		>
			<SiteHeader variant="chat" />

			<!--
				ChatPage is a Svelte component (client:load).
				It handles:
				  - auth bootstrap (gets token from supabase.auth.getSession)
				  - sidebar session list (GET /api/sessions)
				  - renders ChatWindow with sessionId + accessToken
			-->
			<main
				class="relative flex min-h-0 flex-1 overflow-hidden bg-background-dark"
			>
				<ChatPage sessionId={sessionId} client:load />
			</main>
		</div>

		<!-- Inline sidebar toggle (wired to IDs emitted by ChatPage) -->
		<script is:inline>
			document.addEventListener("DOMContentLoaded", () => {
				const sidebar = document.getElementById("chat-sidebar");
				const toggle = document.getElementById("sidebar-toggle");
				const icon = document.getElementById("sidebar-toggle-icon");
				const contentWrap =
					document.getElementById("chat-content-wrap");

				if (!sidebar || !toggle || !icon || !contentWrap) return;

				let isOpen = true;

				const applyState = () => {
					sidebar.classList.toggle("sidebar-hidden", !isOpen);
					contentWrap.classList.toggle("pl-80", isOpen);
					contentWrap.classList.toggle("pl-0", !isOpen);
					toggle.classList.toggle("left-80", isOpen);
					toggle.classList.toggle("left-0", !isOpen);
					icon.textContent = isOpen
						? "chevron_left"
						: "chevron_right";
					toggle.setAttribute("aria-expanded", String(isOpen));
				};

				toggle.addEventListener("click", () => {
					isOpen = !isOpen;
					applyState();
				});

				applyState();
			});
		</script>
	</body>
</html>

<style is:global>
	#chat-sidebar {
		transform: translateX(0);
	}

	#chat-sidebar.sidebar-hidden {
		transform: translateX(-100%);
	}

	.custom-scrollbar::-webkit-scrollbar {
		width: 4px;
	}

	.custom-scrollbar::-webkit-scrollbar-track {
		background: transparent;
	}

	.custom-scrollbar::-webkit-scrollbar-thumb {
		background: rgb(115 17 212 / 20%);
		border-radius: 10px;
	}

	.custom-scrollbar::-webkit-scrollbar-thumb:hover {
		background: rgb(115 17 212 / 50%);
	}

	.mystical-glow {
		box-shadow: 0 0 15px rgb(115 17 212 / 30%);
	}
</style>
