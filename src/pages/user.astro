---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import LibrarySectionNav from "../components/LibrarySectionNav.astro";
import { supabase } from "../lib/supabase";
import UserBioEditor from "../components/UserBioEditor.svelte";

export const prerender = false;

// ── Server-side: fetch the profile by ?id ────────────────────────────────────
const profileId = Astro.url.searchParams.get("id");

type ProfileRow = {
	id: string;
	username: string | null;
	avatar_url: string | null;
	bio: string | null;
	created_at: string | null;
};

let profile: ProfileRow | null = null;
let fetchError = false;

if (profileId) {
	const { data, error } = await supabase
		.from("profiles")
		.select("id, username, avatar_url, bio, created_at")
		.eq("id", profileId)
		.single();

	if (error || !data) {
		fetchError = true;
	} else {
		profile = data as ProfileRow;
	}
}

const displayName = profile?.username?.trim() || "Seeker";
const avatarUrl = profile?.avatar_url?.trim() || "/default_user_profile.png";
const bio = profile?.bio?.trim() || "";
const profileUserId = profile?.id ?? profileId ?? "";

// Pass Supabase public credentials to client scripts
const supabaseUrl =
	import.meta.env.PUBLIC_SUPABASE_URL || import.meta.env.SUPABASE_URL || "";
const supabaseAnonKey =
	import.meta.env.PUBLIC_SUPABASE_ANON_KEY ||
	import.meta.env.SUPABASE_ANON_KEY ||
	"";
---

<html class="dark" lang="en">
	<head>
		<meta charset="utf-8" />
		<meta content="width=device-width, initial-scale=1.0" name="viewport" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Character Chronicle – {displayName}</title>
		<link
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
			rel="stylesheet"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="min-h-screen bg-background-dark font-display text-slate-100">
		<div
			class="relative flex min-h-screen w-full flex-col overflow-x-hidden"
		>
			<div class="layout-container flex h-full grow flex-col">
				<SiteHeader />
				<div class="mx-auto w-full max-w-5xl px-6 pt-6 lg:px-20">
					<LibrarySectionNav active="current-seeker" />
				</div>

				<main
					class="mx-auto w-full max-w-5xl flex-1 px-6 py-8 lg:px-20"
				>
					{
						fetchError || (!profile && profileId) ? (
							<div class="flex flex-col items-center gap-4 py-24 text-center">
								<span class="material-symbols-outlined text-6xl text-primary/30">
									person_off
								</span>
								<p class="text-xl font-bold">User not found</p>
								<p class="text-slate-400">
									This profile does not exist or is
									unavailable.
								</p>
								<a
									href="/"
									class="mt-2 rounded-full border border-primary/30 px-5 py-2 text-sm transition hover:border-primary/60"
								>
									Return home
								</a>
							</div>
						) : !profileId ? (
							<div class="flex flex-col items-center gap-4 py-24 text-center">
								<span class="material-symbols-outlined text-6xl text-primary/30">
									person_search
								</span>
								<p class="text-xl font-bold">
									No profile specified
								</p>
								<p class="text-slate-400">
									Add <code class="text-primary">?id=</code>
									to the URL to view a profile.
								</p>
							</div>
						) : (
							<div class="space-y-8">
								{/* ── Profile header card ── */}
								<div class="relative flex flex-col items-center gap-8 overflow-hidden rounded-xl border border-primary/10 bg-primary/5 p-8 md:flex-row">
									<div class="absolute right-0 top-0 p-4 opacity-10">
										<span class="material-symbols-outlined text-9xl">
											flare
										</span>
									</div>

									{/* Avatar with upload overlay */}
									<div class="relative" id="avatar-wrapper">
										<div class="size-40 rounded-full border-4 border-primary/40 p-1">
											<div
												id="profile-avatar-display"
												class="h-full w-full rounded-full bg-cover bg-center shadow-2xl shadow-primary/20"
												style={`background-image: url('${avatarUrl}')`}
											/>
										</div>

										{/* Upload overlay — shown only to profile owner via JS */}
										<button
											id="avatar-upload-btn"
											class="absolute inset-0 hidden items-center justify-center rounded-full bg-black/50 opacity-0 transition-opacity hover:opacity-100"
											title="Change avatar"
											aria-label="Upload new avatar"
										>
											<span class="material-symbols-outlined text-3xl text-white">
												photo_camera
											</span>
										</button>
										<input
											type="file"
											id="avatar-file-input"
											accept="image/jpeg,image/png,image/webp,image/gif"
											class="hidden"
										/>
									</div>

									<div class="text-center md:text-left">
										<h1 class="mb-1 text-4xl font-extrabold tracking-tight">
											{displayName}
										</h1>
										<p class="text-sm mt-1 text-slate-400">
											Joined{" "}
											{profile!.created_at
												? new Date(
														profile!.created_at,
													).toLocaleDateString(
														"en-US",
														{
															month: "long",
															year: "numeric",
														},
													)
												: "recently"}
										</p>
									</div>
								</div>

								{/* ── Personal Legend (bio) ── */}
								<UserBioEditor
									client:load
									initialBio={bio}
									profileUserId={profileUserId}
									supabaseUrl={supabaseUrl}
									supabaseAnonKey={supabaseAnonKey}
								/>

								{/* ── Created Stories ── */}
								<section
									class="space-y-4"
									id="user-stories-section"
								>
									<div class="flex items-center gap-2">
										<span class="material-symbols-outlined text-primary">
											menu_book
										</span>
										<h3 class="text-2xl font-bold tracking-tight">
											Created Stories
										</h3>
									</div>
									<div
										id="user-stories-grid"
										class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-3"
									>
										<div
											class="animate-pulse rounded-xl border border-primary/10 bg-primary/5"
											style="height:176px"
										/>
										<div
											class="animate-pulse rounded-xl border border-primary/10 bg-primary/5"
											style="height:176px"
										/>
										<div
											class="animate-pulse rounded-xl border border-primary/10 bg-primary/5"
											style="height:176px"
										/>
									</div>
								</section>
							</div>
						)
					}
				</main>

				<SiteFooter />
			</div>
		</div>

		{/* ── Avatar upload status toast ── */}
		<div
			id="avatar-toast"
			class="fixed bottom-6 right-6 hidden items-center gap-2 rounded-lg border border-primary/30 bg-slate-900 px-4 py-3 text-sm shadow-lg"
		>
			<span
				id="avatar-toast-icon"
				class="material-symbols-outlined text-primary"
			>
				check_circle
			</span>
			<span id="avatar-toast-msg">Avatar updated!</span>
		</div>

		<script
			define:vars={{
				profileUserId,
				avatarUrl,
				supabaseUrl,
				supabaseAnonKey,
			}}
		>
			(function () {
				// ── Helpers ─────────────────────────────────────────────────
				function escapeHtml(str) {
					const d = document.createElement("div");
					d.appendChild(document.createTextNode(str));
					return d.innerHTML;
				}

				function showToast(msg, isError) {
					const toast = document.getElementById("avatar-toast");
					const icon = document.getElementById("avatar-toast-icon");
					const msgEl = document.getElementById("avatar-toast-msg");
					if (!toast || !icon || !msgEl) return;
					msgEl.textContent = msg;
					icon.textContent = isError ? "error" : "check_circle";
					icon.className =
						"material-symbols-outlined " +
						(isError ? "text-red-400" : "text-primary");
					toast.classList.remove("hidden");
					toast.classList.add("flex");
					clearTimeout(toast._timer);
					toast._timer = setTimeout(() => {
						toast.classList.add("hidden");
						toast.classList.remove("flex");
					}, 3000);
				}

				// ── Load stories ────────────────────────────────────────────
				async function loadUserStories() {
					const grid = document.getElementById("user-stories-grid");
					if (!grid) return;
					if (!profileUserId) {
						const section = document.getElementById(
							"user-stories-section",
						);
						if (section) section.style.display = "none";
						return;
					}
					try {
						const res = await fetch(
							`/api/stories?author_id=${encodeURIComponent(profileUserId)}&limit=9`,
						);
						if (!res.ok) throw new Error("fetch failed");
						const json = await res.json();
						const stories = json.data?.stories ?? [];
						if (stories.length === 0) {
							grid.innerHTML = `
								<div style="grid-column:1/-1;display:flex;flex-direction:column;align-items:center;gap:12px;padding:40px 0;text-align:center">
									<span class="material-symbols-outlined" style="font-size:48px;color:rgb(115 17 212/0.3)">ink_pen</span>
									<p style="color:#94a3b8">No public stories yet.</p>
								</div>`;
							return;
						}
						grid.innerHTML = stories
							.map(
								(story) => `
							<a href="/review/${escapeHtml(story.id)}"
								style="text-decoration:none;display:flex;flex-direction:column;overflow:hidden;border-radius:12px;border:1px solid rgb(115 17 212/0.1);background:rgb(115 17 212/0.05);transition:border-color 0.2s,background 0.2s"
								onmouseover="this.style.borderColor='rgb(115 17 212/0.4)';this.style.background='rgb(115 17 212/0.1)'"
								onmouseout="this.style.borderColor='rgb(115 17 212/0.1)';this.style.background='rgb(115 17 212/0.05)'">
								<div style="aspect-ratio:16/9;overflow:hidden;background:#1e1a2e">
									${
										story.cover_image_url
											? `<img src="${escapeHtml(story.cover_image_url)}" alt="" style="width:100%;height:100%;object-fit:cover;opacity:0.85;display:block" loading="lazy"/>`
											: `<div style="display:flex;align-items:center;justify-content:center;height:100%;background:linear-gradient(135deg,rgb(115 17 212/0.15),transparent)"><span class="material-symbols-outlined" style="font-size:40px;color:rgb(115 17 212/0.3)">book_2</span></div>`
									}
								</div>
								<div style="padding:14px 16px;flex:1;display:flex;flex-direction:column;gap:4px">
									<p style="font-weight:700;color:#f1f5f9;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
										${escapeHtml(story.title)}
									</p>
									<p style="font-size:11px;color:rgb(115 17 212/0.6);margin-top:auto;padding-top:4px">
										<span class="material-symbols-outlined" style="font-size:13px;vertical-align:middle">library_books</span>
										View Story
									</p>
								</div>
							</a>`,
							)
							.join("");
					} catch {
						grid.innerHTML = `<p style="grid-column:1/-1;text-align:center;color:#64748b;padding:32px 0">Could not load stories.</p>`;
					}
				}

				// ── Owner-only UI (avatar upload) ────────────────────────────
				async function initOwnerUI() {
					// Dynamically import supabase client to check current session
					try {
						const { createClient } =
							await import("https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/+esm");

						// supabaseUrl and supabaseAnonKey are injected via define:vars
						const _sb = createClient(supabaseUrl, supabaseAnonKey);
						const {
							data: { session },
						} = await _sb.auth.getSession();
						if (!session || session.user.id !== profileUserId)
							return;

						const accessToken = session.access_token;

						// Show avatar upload overlay
						const uploadBtn =
							document.getElementById("avatar-upload-btn");
						if (uploadBtn) {
							uploadBtn.classList.remove("hidden");
							uploadBtn.classList.add("flex");
						}

						setupAvatarUpload(accessToken);
					} catch {
						// Non-owner or session unavailable — owner UI stays hidden
					}
				}

				// ── Avatar upload ────────────────────────────────────────────
				function setupAvatarUpload(accessToken) {
					const uploadBtn =
						document.getElementById("avatar-upload-btn");
					const fileInput =
						document.getElementById("avatar-file-input");
					const avatarDisplay = document.getElementById(
						"profile-avatar-display",
					);

					if (!uploadBtn || !fileInput || !avatarDisplay) return;

					uploadBtn.addEventListener("click", () =>
						fileInput.click(),
					);

					fileInput.addEventListener("change", async () => {
						const file = fileInput.files?.[0];
						if (!file) return;

						uploadBtn.disabled = true;
						uploadBtn.innerHTML =
							'<span class="material-symbols-outlined animate-spin text-2xl text-white">progress_activity</span>';

						const formData = new FormData();
						formData.append("file", file);

						try {
							const res = await fetch("/api/user/upload-avatar", {
								method: "POST",
								headers: {
									Authorization: `Bearer ${accessToken}`,
								},
								body: formData,
							});
							const json = await res.json();
							if (!res.ok || !json.success) {
								throw new Error(json.error || "Upload failed");
							}

							// Update avatar display immediately
							const newUrl = json.url;
							avatarDisplay.style.backgroundImage = `url("${newUrl}")`;

							// Also update header avatar if present
							document
								.querySelectorAll("[data-profile-avatar]")
								.forEach((node) => {
									if (node instanceof HTMLImageElement) {
										node.src = newUrl;
									} else if (node instanceof HTMLElement) {
										node.style.backgroundImage = `url("${newUrl}")`;
									}
								});

							// Sync localStorage cache
							try {
								const stored =
									localStorage.getItem("talora.profile");
								if (stored) {
									const p = JSON.parse(stored);
									p.avatar_url = newUrl;
									localStorage.setItem(
										"talora.profile",
										JSON.stringify(p),
									);
								}
							} catch {}

							showToast("Avatar updated!", false);
						} catch (err) {
							showToast(err.message || "Upload failed", true);
						} finally {
							uploadBtn.disabled = false;
							uploadBtn.innerHTML =
								'<span class="material-symbols-outlined text-3xl text-white">photo_camera</span>';
							fileInput.value = "";
						}
					});
				}

				// ── Boot ─────────────────────────────────────────────────────
				loadUserStories();
				initOwnerUI();
			})();
		</script>
	</body>
</html>
