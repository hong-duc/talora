													</button>
													<button
														id="attach-story-btn"
														class="flex items-center gap-1 transition-colors hover:text-accent-gold"
														title="Attach story"
													>
														<span class="material-symbols-outlined text-[20px]">
															auto_stories
														</span>
													</button>
													<button
														id="attach-character-btn"
														class="flex items-center gap-1 transition-colors hover:text-accent-gold"
														title="Attach character"
													>
														<span class="material-symbols-outlined text-[20px]">
															token
														</span>
													</button>
												</div>
												<button
													id="submit-post-btn"
													class="rounded-lg bg-primary px-6 py-2 text-sm font-bold text-white shadow-lg shadow-primary/30 transition-all hover:bg-primary/90 hover:scale-105 disabled:opacity-50 disabled:cursor-not-allowed"
												>
													Echo
												</button>
											</div>
										</div>
									</div>
								</div>
							) : (
								<div class="rounded-xl border border-primary/20 bg-surface-container p-8 text-center">
									<p class="text-lg text-slate-400 mb-4">
										Sign in to share your own echoes.
									</p>
									<a
										href="/signin"
										class="inline-block rounded-lg bg-primary px-6 py-2 text-sm font-bold text-white shadow-lg shadow-primary/30 transition-all hover:bg-primary/90 hover:scale-105"
									>
										Sign In
									</a>
								</div>
							)
						}

						<!-- Posts Feed -->
						<div id="posts-feed" class="flex flex-col gap-6 mt-6">
							<div
								id="posts-empty"
								class="hidden rounded-xl border border-primary/10 bg-surface-container p-16 text-center"
							>
								<span
									class="material-symbols-outlined mb-4 block text-5xl text-primary/40"
									>forum</span
								>
								<p
									class="mb-2 text-2xl font-bold text-slate-300"
								>
									The hall is silent.
								</p>
								<p class="text-sm text-slate-500">
									No echoes yet. Be the first to share a
									whisper.
								</p>
							</div>
							<div
								id="posts-loading"
								class="rounded-xl border border-primary/10 bg-surface-container p-16 text-center"
							>
								<span
									class="material-symbols-outlined mb-4 block text-5xl text-primary/40 animate-spin"
									>hourglass</span
								>
								<p class="text-sm text-slate-500">
									Listening for echoes...
								</p>
							</div>
						</div>
					</section>

					<!-- RIGHT SIDEBAR -->
					<aside class="w-full md:w-72">
						<div
							class="glass-card rounded-xl border border-primary/20 p-6"
						>
							<h3
								class="mb-6 flex items-center justify-between font-bold text-slate-100"
							>
								Fellow <span class="gold-shimmer">Seekers</span>
								<a
									href="/social/seekers"
									class="text-xs font-medium uppercase tracking-tight text-accent-gold hover:underline"
									>See all</a
								>
							</h3>
							<div class="flex flex-col gap-3">
								<p class="text-sm text-slate-500 italic">
									Discover fellow readers and authors
									wandering the library's halls.
								</p>
								<a
									href="/social/seekers"
									class="rounded-lg border border-primary/20 px-4 py-2 text-center text-sm text-primary hover:bg-primary/10 transition-colors"
								>
									Browse Seekers
								</a>
							</div>
						</div>
					</aside>
				</main>

				<SiteFooter />
			</div>
		</div>

		<!-- Post Template (hidden, used by JS) -->
		<template id="post-template">
			<div
				class="glass-card relative overflow-hidden rounded-xl border border-primary/10"
			>
				<div class="p-6">
					<div class="mb-4 flex items-center gap-3">
						<div
							class="post-avatar size-10 rounded-full bg-cover bg-center ring-2 ring-accent-gold/30"
						>
						</div>
						<div>
							<p class="post-username text-sm font-bold"></p>
							<p class="post-time text-xs italic text-slate-500">
							</p>
						</div>
						<div
							class="post-badge ml-auto hidden rounded-full bg-accent-gold/20 px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-accent-gold"
						>
							Story Attached
						</div>

						<!-- Post action dropdown (edit/delete) — hidden by default, shown only for own posts -->
						<div class="post-actions relative ml-2 hidden">
							<button
								class="post-actions-trigger flex items-center justify-center rounded-full p-1 text-slate-500 transition-colors hover:bg-primary/10 hover:text-accent-gold"
								title="More actions"
							>
								<span class="material-symbols-outlined text-[20px]">more_vert</span>
							</button>
							<div class="post-actions-dropdown absolute right-0 top-full z-20 mt-1 hidden w-36 rounded-lg border border-primary/20 bg-surface-container shadow-xl shadow-black/30">
								<button
									class="post-action-edit flex w-full items-center gap-2 rounded-t-lg px-3 py-2.5 text-sm text-slate-300 transition-colors hover:bg-primary/10 hover:text-accent-gold"
								>
									<span class="material-symbols-outlined text-[18px]">edit</span>
									Edit
								</button>
								<button
									class="post-action-delete flex w-full items-center gap-2 rounded-b-lg px-3 py-2.5 text-sm text-slate-300 transition-colors hover:bg-red-500/10 hover:text-red-400"
								>
									<span class="material-symbols-outlined text-[18px]">delete</span>
									Delete
								</button>
							</div>
						</div>
					</div>
					<p
						class="post-content mb-4 text-lg italic leading-relaxed text-slate-200"
					>
					</p>
					<!-- Edit textarea (hidden by default) -->
					<textarea
						class="post-edit-textarea hidden mb-4 w-full resize-none rounded-lg border border-accent-gold/30 bg-slate-900 p-3 text-lg italic leading-relaxed text-slate-200 focus:ring-1 focus:ring-accent-gold/50"
						rows="3"
						maxlength="5000"
					></textarea>
					<!-- Edit actions (hidden by default) -->
					<div class="post-edit-actions hidden mb-4 flex items-center gap-2">
						<button
							class="post-edit-save rounded-lg bg-primary px-4 py-1.5 text-sm font-bold text-white transition-all hover:bg-primary/90"
						>
							Save
						</button>
						<button
							class="post-edit-cancel rounded-lg border border-primary/20 px-4 py-1.5 text-sm text-slate-400 transition-all hover:text-slate-200"
						>
							Cancel
						</button>
					</div>
					<!-- Delete confirmation (hidden by default) -->
					<div class="post-delete-confirm hidden mb-4 rounded-lg border border-red-500/20 bg-red-500/5 p-4">
						<p class="mb-3 text-sm text-slate-300">Delete this echo? This action cannot be undone.</p>
						<div class="flex items-center gap-2">
							<button
								class="post-delete-confirm-btn rounded-lg bg-red-600 px-4 py-1.5 text-sm font-bold text-white transition-all hover:bg-red-500"
							>
								Delete
							</button>
							<button
								class="post-delete-cancel rounded-lg border border-primary/20 px-4 py-1.5 text-sm text-slate-400 transition-all hover:text-slate-200"
							>
								Keep
							</button>
						</div>
					</div>
					<div class="post-images mb-4 hidden flex-wrap gap-2"></div>
					<div
						class="post-story-card mb-4 hidden rounded-lg border border-accent-gold/20 bg-surface-dim p-4"
					>
					</div>
					<div class="flex items-center gap-6 text-slate-500">
						<button
							class="btn-like flex items-center gap-2 text-sm hover:text-accent-gold transition-colors"
						>
							<span class="material-symbols-outlined text-[20px]"
								>favorite</span
							>
							<span class="like-count">0</span>
						</button>
						<button
							class="btn-comment flex items-center gap-2 text-sm hover:text-accent-gold transition-colors"
						>
							<span class="material-symbols-outlined text-[20px]"
								>chat_bubble</span
							>
							<span class="comment-count">0</span>
						</button>
						<button
							class="btn-repost flex items-center gap-2 text-sm hover:text-accent-gold transition-colors"
						>
							<span class="material-symbols-outlined text-[20px]"
								>share</span
							>
							<span class="repost-count">0</span>
						</button>
					</div>
				</div>
			</div>
		</template>
	</body>
</html>

<script define:vars={{ postsJson, isLoggedInJson, currentUserIdJson, defaultAvatar }}>
	const isLoggedIn = JSON.parse(isLoggedInJson);
	const currentUserId = JSON.parse(currentUserIdJson);
	let posts = JSON.parse(postsJson);

	const feed = document.getElementById("posts-feed");
	const emptyState = document.getElementById("posts-empty");
	const loadingState = document.getElementById("posts-loading");
	const template = document.getElementById("post-template");

	// Helper to get access token from cookies
	function getAccessToken() {
		const cookies = document.cookie.split("; ");
		for (const c of cookies) {
			const idx = c.indexOf("=");
			if (idx > -1) {
				const key = c.slice(0, idx);
				const val = c.slice(idx + 1);
				if (key === "sb-access-token") return val;
			}
		}
		return null;
	}

	// ── Close all open dropdowns ──────────────────────────────────────────────
	function closeAllDropdowns() {
		document.querySelectorAll(".post-actions-dropdown:not(.hidden)").forEach(function (dd) {
			dd.classList.add("hidden");
		});
	}

	// Close dropdowns when clicking outside
	document.addEventListener("click", function (e) {
		if (!e.target.closest(".post-actions")) {
			closeAllDropdowns();
		}
	});

	// ── Render posts ────────────────────────────────────────────────────────
	function renderPosts() {
		feed.querySelectorAll(".post-card").forEach(function (el) {
			el.remove();
		});

		if (posts.length === 0) {
			loadingState.classList.add("hidden");
			emptyState.classList.remove("hidden");
			return;
		}

		loadingState.classList.add("hidden");
		emptyState.classList.add("hidden");

		posts.forEach(function (post) {
			const clone = template.content.cloneNode(true);
			const card = clone.querySelector(".glass-card");
			card.classList.add("post-card");
			card.setAttribute("data-post-id", post.id);

			// Avatar
			const avatarEl = clone.querySelector(".post-avatar");
			avatarEl.style.backgroundImage =
				"url('" +
				(post.author && post.author.avatar_url
					? post.author.avatar_url
					: defaultAvatar) +
				"')";

			// Username + time
			clone.querySelector(".post-username").textContent =
				(post.author && post.author.username) || "Unknown Seeker";
			clone.querySelector(".post-time").textContent = post.timeAgo || "";

			// Content
			clone.querySelector(".post-content").textContent = post.content;

			// ── Owner actions (edit/delete dropdown) ──────────────────────────
			const actionsContainer = clone.querySelector(".post-actions");
			if (currentUserId && post.author_id === currentUserId) {
				actionsContainer.classList.remove("hidden");

				// Dropdown toggle
				const trigger = actionsContainer.querySelector(".post-actions-trigger");
				const dropdown = actionsContainer.querySelector(".post-actions-dropdown");

				trigger.addEventListener("click", function (e) {
					e.stopPropagation();
					const isOpen = !dropdown.classList.contains("hidden");
					closeAllDropdowns();
					if (!isOpen) {
						dropdown.classList.remove("hidden");
					}
				});

				// Edit action
				const editBtn = actionsContainer.querySelector(".post-action-edit");
				const contentP = clone.querySelector(".post-content");
				const editTextarea = clone.querySelector(".post-edit-textarea");
				const editActions = clone.querySelector(".post-edit-actions");
				const editSave = clone.querySelector(".post-edit-save");
				const editCancel = clone.querySelector(".post-edit-cancel");
				const deleteConfirm = clone.querySelector(".post-delete-confirm");

				editBtn.addEventListener("click", function () {
					dropdown.classList.add("hidden");
					// Hide view mode
					contentP.classList.add("hidden");
					// Show edit mode
					editTextarea.value = post.content;
					editTextarea.classList.remove("hidden");
					editActions.classList.remove("hidden");
					editTextarea.focus();
				});

				editSave.addEventListener("click", async function () {
					const newContent = editTextarea.value.trim();
					if (!newContent || newContent === post.content) {
						// Revert
						editTextarea.classList.add("hidden");
						editActions.classList.add("hidden");
						contentP.classList.remove("hidden");
						return;
					}

					const token = getAccessToken();
					editSave.setAttribute("disabled", "true");
					editSave.textContent = "Saving...";

					try {
						const res = await fetch("/api/posts/" + post.id, {
							method: "PUT",
							headers: {
								"Content-Type": "application/json",
								Authorization: "Bearer " + token,
							},
							body: JSON.stringify({ content: newContent }),
						});
						const data = await res.json();
						if (res.ok && data.success) {
							post.content = newContent;
							contentP.textContent = newContent;
							editTextarea.classList.add("hidden");
							editActions.classList.add("hidden");
							contentP.classList.remove("hidden");
						} else {
							alert(data.error || "Failed to update post");
						}
					} catch (err) {
						console.error("Edit failed:", err);
						alert("Failed to update post");
					} finally {
						editSave.removeAttribute("disabled");
						editSave.textContent = "Save";
					}
				});

				editCancel.addEventListener("click", function () {
					editTextarea.classList.add("hidden");
					editActions.classList.add("hidden");
					contentP.classList.remove("hidden");
				});

				// Delete action
				const deleteBtn = actionsContainer.querySelector(".post-action-delete");
				const deleteConfirmBtn = clone.querySelector(".post-delete-confirm-btn");
				const deleteCancelBtn = clone.querySelector(".post-delete-cancel");

				deleteBtn.addEventListener("click", function () {
					dropdown.classList.add("hidden");
					deleteConfirm.classList.remove("hidden");
				});

				deleteCancelBtn.addEventListener("click", function () {
					deleteConfirm.classList.add("hidden");
				});

				deleteConfirmBtn.addEventListener("click", async function () {
					const token = getAccessToken();
					deleteConfirmBtn.setAttribute("disabled", "true");
					deleteConfirmBtn.textContent = "Deleting...";

					try {
						const res = await fetch("/api/posts/" + post.id, {
							method: "DELETE",
							headers: {
								Authorization: "Bearer " + token,
							},
						});
						const data = await res.json();
						if (res.ok && data.success) {
							// Remove from array and DOM with fade
							card.style.transition = "opacity 0.3s, transform 0.3s";
							card.style.opacity = "0";
							card.style.transform = "scale(0.95)";
							setTimeout(function () {
								card.remove();
								// Remove from posts array
								posts = posts.filter(function (p) { return p.id !== post.id; });
								if (posts.length === 0) {
									emptyState.classList.remove("hidden");
								}
							}, 300);
						} else {
							alert(data.error || "Failed to delete post");
							deleteConfirmBtn.removeAttribute("disabled");
							deleteConfirmBtn.textContent = "Delete";
						}
					} catch (err) {
						console.error("Delete failed:", err);
						alert("Failed to delete post");
						deleteConfirmBtn.removeAttribute("disabled");
						deleteConfirmBtn.textContent = "Delete";
					}
				});
			}

			// Story badge & card
			if (post.story) {
				clone.querySelector(".post-badge").classList.remove("hidden");
				const storyCard = clone.querySelector(".post-story-card");
				storyCard.classList.remove("hidden");
				const title = post.story.title
					.replace(/&/g, "&")
					.replace(/</g, "<")
					.replace(/>/g, ">");
				storyCard.innerHTML =
					'<p class="text-xs text-slate-400">Attached Story</p><p class="font-bold text-accent-gold">' +
					title +
					"</p>";
			}

			// Images
			if (post.image_urls && post.image_urls.length) {
				const imagesDiv = clone.querySelector(".post-images");
				imagesDiv.classList.remove("hidden");
				post.image_urls.forEach(function (url) {
					const img = document.createElement("img");
					img.src = url;
					img.className =
						"h-32 w-32 rounded-lg object-cover border border-primary/10";
					imagesDiv.appendChild(img);
				});
			}

			// Counters
			const likeBtn = clone.querySelector(".btn-like");
			const likeCount = likeBtn.querySelector(".like-count");
			likeCount.textContent = String(post.like_count || 0);
			if (post.liked_by_me) {
				likeBtn.classList.add("text-accent-gold");
				likeBtn.querySelector(
					".material-symbols-outlined",
				).textContent = "favorite";
			}

			clone.querySelector(".comment-count").textContent = String(
				post.comment_count || 0,
			);

			const repostBtn = clone.querySelector(".btn-repost");
			const repostCount = repostBtn.querySelector(".repost-count");
			repostCount.textContent = String(post.repost_count || 0);
			if (post.reposted_by_me) {
				repostBtn.classList.add("text-accent-gold");
			}

			// Wire up interaction buttons
			likeBtn.addEventListener("click", function () {
				handleLike(post.id, likeBtn, likeCount);
			});
			repostBtn.addEventListener("click", function () {
				handleRepost(post.id, repostBtn, repostCount);
			});

			feed.appendChild(clone);
		});
	}

	// ── Like toggle ─────────────────────────────────────────────────────────
	async function handleLike(postId, btn, countEl) {
		if (!isLoggedIn) {
			window.location.href = "/signin";
			return;
		}

		const token = getAccessToken();
		try {
			const res = await fetch("/api/posts/" + postId + "/like", {
				method: "POST",
				headers: {
					"Content-Type": "application/json",
					Authorization: "Bearer " + token,
				},
			});
			const data = await res.json();
			if (res.ok) {
				countEl.textContent = String(data.like_count);
				if (data.liked) {
					btn.classList.add("text-accent-gold");
				} else {
					btn.classList.remove("text-accent-gold");
				}
			}
		} catch (err) {
			console.error("Like failed:", err);
		}
	}

	// ── Repost toggle ───────────────────────────────────────────────────────
	async function handleRepost(postId, btn, countEl) {
		if (!isLoggedIn) {
			window.location.href = "/signin";
			return;
		}

		const token = getAccessToken();
		const isReposted = btn.classList.contains("text-accent-gold");
		try {
			const res = await fetch("/api/posts/" + postId + "/repost", {
				method: isReposted ? "DELETE" : "POST",
				headers: {
					"Content-Type": "application/json",
					Authorization: "Bearer " + token,
				},
			});
			const data = await res.json();
			if (res.ok) {
				if (isReposted) {
					btn.classList.remove("text-accent-gold");
					countEl.textContent = String(
						Math.max(0, parseInt(countEl.textContent || "1") - 1),
					);
				} else {
					btn.classList.add("text-accent-gold");
					countEl.textContent = String(
						parseInt(countEl.textContent || "0") + 1,
					);
				}
			}
		} catch (err) {
			console.error("Repost failed:", err);
		}
	}

	// ── Create Post ─────────────────────────────────────────────────────────
	const submitBtn = document.getElementById("submit-post-btn");
	const textarea = document.getElementById("create-post-textarea");

	if (submitBtn) {
		submitBtn.addEventListener("click", async function () {
			if (!textarea) return;
			const content = textarea.value.trim();
			if (!content) return;

			const token = getAccessToken();
			submitBtn.setAttribute("disabled", "true");
			submitBtn.textContent = "Echoing...";

			try {
				const res = await fetch("/api/posts", {
					method: "POST",
					headers: {
						"Content-Type": "application/json",
						Authorization: "Bearer " + token,
					},
					body: JSON.stringify({
						content: content,
						visibility: "public",
					}),
				});
				const data = await res.json();
				if (res.ok && data.post) {
					const newPost = {
						id: data.post.id,
						content: data.post.content,
						author_id: data.post.author_id,
						story_id: data.post.story_id,
						character_id: data.post.character_id,
						image_urls: data.post.image_urls || [],
						visibility: data.post.visibility,
						like_count: data.post.like_count,
						comment_count: data.post.comment_count,
						repost_count: data.post.repost_count,
						created_at: data.post.created_at,
						updated_at: data.post.updated_at,
						timeAgo: "just now",
						liked_by_me: false,
						reposted_by_me: false,
						author: data.post.author,
						story: null,
						character: null,
					};
					posts.unshift(newPost);
					renderPosts();
					textarea.value = "";
				} else {
					alert(data.error || "Failed to create post");
				}
			} catch (err) {
				console.error("Create post failed:", err);
				alert("Failed to create post");
			} finally {
				submitBtn.removeAttribute("disabled");
				submitBtn.textContent = "Echo";
			}
		});
	}

	// Auto-resize textarea
	if (textarea) {
		textarea.addEventListener("input", function () {
			textarea.style.height = "auto";
			textarea.style.height = Math.min(textarea.scrollHeight, 200) + "px";
		});
	}

	// ── Initial render ──────────────────────────────────────────────────────
	renderPosts();
</script>