							</h3>
							<div class="flex flex-col gap-3">
								<p class="text-sm text-slate-500 italic">
									Discover fellow readers and authors
									wandering the library's halls.
								</p>
								<a
									href="/social/seekers"
									class="rounded-lg border border-primary/20 px-4 py-2 text-center text-sm text-primary hover:bg-primary/10 transition-colors"
								>
									Browse Seekers
								</a>
							</div>
						</div>
					</aside>
				</main>

				<SiteFooter />
			</div>
		</div>

		<!-- Post Template (hidden, used by JS) -->
		<template id="post-template">
			<div
				class="glass-card relative overflow-hidden rounded-xl border border-primary/10"
			>
				<!-- Post action dropdown (edit/delete) — positioned top-right corner -->
				<div class="post-actions absolute top-3 right-3 z-10 hidden">
					<button
						class="post-actions-trigger flex items-center justify-center rounded-full p-1 text-slate-500 transition-colors hover:bg-primary/10 hover:text-accent-gold"
						title="More actions"
					>
						<span class="material-symbols-outlined text-[20px]">more_vert</span>
					</button>
					<div class="post-actions-dropdown absolute right-0 top-full z-20 mt-1 hidden w-36 rounded-lg border border-primary/20 bg-surface-container shadow-xl shadow-black/30">
						<button
							class="post-action-edit flex w-full items-center gap-2 rounded-t-lg px-3 py-2.5 text-sm text-slate-300 transition-colors hover:bg-primary/10 hover:text-accent-gold"
						>
							<span class="material-symbols-outlined text-[18px]">edit</span>
							Edit
						</button>
						<button
							class="post-action-delete flex w-full items-center gap-2 rounded-b-lg px-3 py-2.5 text-sm text-slate-300 transition-colors hover:bg-red-500/10 hover:text-red-400"
						>
							<span class="material-symbols-outlined text-[18px]">delete</span>
							Delete
						</button>
					</div>
				</div>

				<div class="p-6">
					<div class="mb-4 flex items-center gap-3">
						<div
							class="post-avatar size-10 rounded-full bg-cover bg-center ring-2 ring-accent-gold/30"
						>
						</div>
						<div>
							<p class="post-username text-sm font-bold"></p>
							<p class="post-time text-xs italic text-slate-500">
							</p>
						</div>
						<div
							class="post-badge ml-auto hidden rounded-full bg-accent-gold/20 px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-accent-gold"
						>
							Story Attached
						</div>
					</div>
					<p
						class="post-content mb-4 text-lg italic leading-relaxed text-slate-200"
					>
					</p>
					<!-- Edit textarea (hidden by default) -->
					<textarea
						class="post-edit-textarea hidden mb-4 w-full resize-none rounded-lg border border-accent-gold/30 bg-slate-900 p-3 text-lg italic leading-relaxed text-slate-200 focus:ring-1 focus:ring-accent-gold/50"
						rows="3"
						maxlength="5000"
					></textarea>
					<!-- Edit actions (hidden by default) -->
					<div class="post-edit-actions hidden mb-4 items-center gap-2">
						<button
							class="post-edit-save rounded-lg bg-primary px-4 py-1.5 text-sm font-bold text-white transition-all hover:bg-primary/90"
						>
							Save
						</button>
						<button
							class="post-edit-cancel rounded-lg border border-primary/20 px-4 py-1.5 text-sm text-slate-400 transition-all hover:text-slate-200"
						>
							Cancel
						</button>
					</div>
					<!-- Delete confirmation (hidden by default) -->
					<div class="post-delete-confirm hidden mb-4 rounded-lg border border-red-500/20 bg-red-500/5 p-4">
						<p class="mb-3 text-sm text-slate-300">Delete this echo? This action cannot be undone.</p>
						<div class="flex items-center gap-2">
							<button
								class="post-delete-confirm-btn rounded-lg bg-red-600 px-4 py-1.5 text-sm font-bold text-white transition-all hover:bg-red-500"
							>
								Delete
							</button>
							<button
								class="post-delete-cancel rounded-lg border border-primary/20 px-4 py-1.5 text-sm text-slate-400 transition-all hover:text-slate-200"
							>
								Keep
							</button>
						</div>
					</div>
					<div class="post-images mb-4 hidden flex-wrap gap-2"></div>
					<div
						class="post-story-card mb-4 hidden rounded-lg border border-accent-gold/20 bg-surface-dim p-4"
					>
					</div>
					<div class="flex items-center gap-6 text-slate-500">
						<button
							class="btn-like flex items-center gap-2 text-sm hover:text-accent-gold transition-colors"
						>
							<span class="material-symbols-outlined text-[20px]"
