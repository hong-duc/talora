---
import "../../styles/global.css";
import SiteFooter from "../../components/SiteFooter.astro";
import SiteHeader from "../../components/SiteHeader.astro";
---

<html class="dark" lang="en">
	<head>
		<meta charset="utf-8" />
		<meta content="width=device-width, initial-scale=1.0" name="viewport" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>The Hall of Echoes - The Whispering Library</title>
		<link
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
			rel="stylesheet"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="min-h-screen bg-background-dark text-slate-100">
		<div
			class="relative flex min-h-screen w-full flex-col overflow-x-hidden"
		>
			<div class="layout-container flex h-full grow flex-col">
				<SiteHeader activeSection="social" />

				<main
					class="mx-auto flex w-full max-w-[1440px] flex-1 flex-col gap-10 px-6 py-10 md:flex-row lg:px-20"
				>
					<aside class="w-full shrink-0 md:w-64">
						<div
							class="rounded-xl border border-primary/10 bg-primary/5 p-6"
						>
							<h3
								class="font-display mb-1 text-lg font-bold text-primary"
							>
								The Sanctum
							</h3>
							<p class="mb-6 text-sm text-slate-400">
								Seeker Rank: High Archivist
							</p>
							<nav class="flex flex-col gap-2">
								<a
									class="flex items-center gap-3 rounded-lg bg-primary px-3 py-2.5 text-white"
									href="#"
								>
									<span
										class="material-symbols-outlined text-[20px]"
										>forum</span
									>
									<span class="text-sm font-medium"
										>Hall of Echoes</span
									>
								</a>
								<a
									class="flex items-center gap-3 rounded-lg px-3 py-2.5 transition-colors hover:bg-primary/10"
									href="#"
								>
									<span
										class="material-symbols-outlined text-[20px] text-primary"
										>menu_book</span
									>
									<span class="text-sm font-medium"
										>My Library</span
									>
								</a>
								<a
									class="flex items-center gap-3 rounded-lg px-3 py-2.5 transition-colors hover:bg-primary/10"
									href="#"
								>
									<span
										class="material-symbols-outlined text-[20px] text-primary"
										>diamond</span
									>
									<span class="text-sm font-medium"
										>Artifact Gallery</span
									>
								</a>
								<a
									class="flex items-center gap-3 rounded-lg px-3 py-2.5 transition-colors hover:bg-primary/10"
									href="/social/group"
								>
									<span
										class="material-symbols-outlined text-[20px] text-primary"
										>groups</span
									>
									<span class="text-sm font-medium"
										>Scholarly Circles</span
									>
								</a>
							</nav>
						</div>
						<div
							class="mt-8 rounded-xl border border-primary/10 bg-primary/5 p-6"
						>
							<h3
								class="mb-4 flex items-center gap-2 font-bold text-slate-100"
							>
								<span
									class="material-symbols-outlined text-primary"
									>auto_awesome</span
								>
								Trending Whispers
							</h3>
							<ul class="flex flex-col gap-3">
								<li>
									<a
										class="text-sm italic text-primary hover:underline"
										href="#">#TheLostCodex</a>
								</li>
								<li>
									<a
										class="text-sm italic text-primary hover:underline"
										href="#">#EchoesFromGlowormCaves</a>
								</li>
								<li>
									<a
										class="text-sm italic text-primary hover:underline"
										href="#">#StarChartPuzzle</a>
								</li>
								<li>
									<a
										class="text-sm italic text-primary hover:underline"
										href="#">#MidnightInTheArchives</a>
								</li>
							</ul>
						</div>
					</aside>

					<section class="min-w-0 flex-1 flex-col gap-8 md:flex">
						<div>
							<h1
								class="font-display text-4xl font-black tracking-tight text-slate-100"
							>
								The Hall of Echoes
							</h1>
							<p class="mt-2 text-slate-400">
								A communal space for seekers of lost knowledge
								and whispered tales.
							</p>
						</div>

						<div
							class="rounded-xl border border-primary/20 bg-primary/5 p-4"
						>
							<div class="flex gap-4">
								<div
									class="size-12 shrink-0 rounded-full border border-primary bg-primary/20 bg-cover bg-center"
									style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBOK-fhfRJkgaU0q9ZXrBi_oC0yRUInCXuuGH9-oulWaH3_zrE7Y1RWhvsKVWZ9gUDQBCuc1cflBrIVpOOdfqptVgJXuWb_4cQc7TWUJkd70B31MJyCJGsNn59bx6Owm5rzQs9OQQw_r6iIlffGf7GGL4ofk3siIwd7wZkH2rpHTGPCI0w8zooI8faFeI5bw9Qj36IAVSbXc55DKAKAT-3Pd4WO9DEW8ru0iYxzGLEIm10hQHKxlxP-6zayUL9Z7ucpXqkbIKDFd7Y')"
								>
								</div>
								<div class="flex-1">
									<textarea
										class="w-full resize-none border-none bg-transparent text-lg italic text-slate-100 placeholder:text-slate-500 focus:ring-0"
										placeholder="Share a discovery or a whisper..."
										rows="2"></textarea>
									<div
										class="mt-4 flex items-center justify-between border-t border-primary/10 pt-4"
									>
										<div class="flex gap-4 text-slate-500">
											<button
												class="flex items-center gap-1 transition-colors hover:text-primary"
											>
												<span
													class="material-symbols-outlined text-[20px]"
													>image</span
												>
											</button>
											<button
												class="flex items-center gap-1 transition-colors hover:text-primary"
											>
												<span
													class="material-symbols-outlined text-[20px]"
													>auto_stories</span
												>
											</button>
											<button
												class="flex items-center gap-1 transition-colors hover:text-primary"
											>
												<span
													class="material-symbols-outlined text-[20px]"
													>token</span
												>
											</button>
										</div>
										<button
											class="rounded-lg bg-primary px-6 py-2 text-sm font-bold text-white transition-opacity hover:opacity-90"
											>Echo</button
										>
									</div>
								</div>
							</div>
						</div>

						<div class="flex flex-col gap-6">
							<div
								class="overflow-hidden rounded-xl border border-primary/10 bg-primary/5"
							>
								<div class="p-6">
									<div class="mb-4 flex items-center gap-3">
										<div
											class="size-10 rounded-full bg-cover bg-center"
											style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBF9pDCmXpL2cFqOtzYtFkMG2xpkaNaIBmI3K0BEpO-ASOcofyY5SGnXmZgMVwzJRKva3J5odD5XiGNRGA1nX27CAonXHg748Hvhe1RKa7D4tC24qWOTVfhNyYaVWhOurtHqj4BHygBvUu-y1Oskufc5J3ALTXce_T5gFYR0uq_GE7yxexyiva1qzHIfhoF_IO5q6cwcvOp_-GGwayIMvX84q3n8okEh6C0t2pr_Q2gWZAkPwmSFPpCiSLyMC0N_4jiQA_2Wnlrd7Y')"
										>
										</div>
										<div>
											<p class="text-sm font-bold">
												Archivist Silas
											</p>
											<p
												class="text-xs italic text-slate-500"
											>
												2 hours ago in The Sunken
												Library
											</p>
										</div>
										<div class="ml-auto text-primary">
											<span
												class="material-symbols-outlined"
												>stars</span
											>
										</div>
									</div>
									<p
										class="mb-4 text-lg italic leading-relaxed text-slate-200"
									>
										"After three nights of decoding the
										lunar glyphs, I've finally unearthed the
										'Prism of Veiled Sight'. Its glow is
										faint, but it reveals paths I never knew
										existed in the fourth chapter."
									</p>
									<div
										class="relative mb-4 h-48 w-full overflow-hidden rounded-lg border border-primary/20 bg-background-dark"
									>
										<div
											class="absolute inset-0 bg-linear-to-tr from-primary/40 to-transparent"
										>
										</div>
										<div
											class="flex h-full items-center justify-center"
										>
											<span
												class="material-symbols-outlined text-6xl text-primary/60"
												>diamond</span
											>
										</div>
										<div
											class="absolute bottom-4 left-4 right-4 flex items-center justify-between rounded-lg bg-background-dark/80 p-3 backdrop-blur-md"
										>
											<span
												class="text-xs font-bold uppercase tracking-widest"
												>New Artifact Unlocked</span
											>
											<span
												class="text-xs font-bold text-primary"
												>Prism of Veiled Sight</span
											>
										</div>
									</div>
									<div
										class="flex items-center gap-6 text-slate-500"
									>
										<button
											class="flex items-center gap-2 text-sm hover:text-primary"
										>
											<span
												class="material-symbols-outlined text-[20px]"
												>favorite</span
											>
											24
										</button>
										<button
											class="flex items-center gap-2 text-sm hover:text-primary"
										>
											<span
												class="material-symbols-outlined text-[20px]"
												>chat_bubble</span
											>
											8
										</button>
										<button
											class="flex items-center gap-2 text-sm hover:text-primary"
										>
											<span
												class="material-symbols-outlined text-[20px]"
												>share</span
											>
										</button>
									</div>
								</div>
							</div>

							<div
								class="rounded-xl border border-primary/10 bg-primary/5 p-6"
							>
								<div class="mb-4 flex items-center gap-3">
									<div
										class="size-10 rounded-full bg-cover bg-center"
										style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuA8SwBOxqRbXeRekQu1zrzykcxNQ4paa-7YVt1_CGCIWOk5TsbeUMYtpBOCo8btHjCjiCCpOCxIDqhkhSlxyakWI5VrKo8mtGla3nbpJJ4X_QL7j7VKxDFgme2ODQwAIArbcCq6ob-9UCJ4btZsF4JcTmUZueT4578a6QBu2MDJfjNb-MP1YGKzVeXozdG-PoHW-x9SeNGJzHzO91QztZgDe633v0n1ooJvyg1W8lg5naYdqmwfiEYJAteafZxNpaKl1BnCKTXPyYQ')"
									>
									</div>
									<div>
										<p class="text-sm font-bold">
											Seeker Elena
										</p>
										<p
											class="text-xs italic text-slate-500"
										>
											5 hours ago
										</p>
									</div>
									<div
										class="ml-auto rounded-full bg-primary/20 px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-primary"
									>
										Story Milestone
									</div>
								</div>
								<p
									class="mb-4 text-lg italic leading-relaxed text-slate-200"
								>
									"The Choice at the Obsidian Gate... I chose
									to trust the Shadow. The narrative has
									shifted entirely. Has anyone else seen the
									murals change in the main hall after this?"
								</p>
								<div
									class="flex items-center gap-6 text-slate-500"
								>
									<button
										class="flex items-center gap-2 text-sm hover:text-primary"
									>
										<span
											class="material-symbols-outlined text-[20px]"
											>favorite</span
										>
										52
									</button>
									<button
										class="flex items-center gap-2 text-sm hover:text-primary"
									>
										<span
											class="material-symbols-outlined text-[20px]"
											>chat_bubble</span
										>
										15
									</button>
									<button
										class="flex items-center gap-2 text-sm hover:text-primary"
									>
										<span
											class="material-symbols-outlined text-[20px]"
											>share</span
										>
									</button>
								</div>
							</div>
						</div>
					</section>

					<aside class="w-full md:w-72">
						<div
							class="rounded-xl border border-primary/10 bg-primary/5 p-6"
						>
							<h3
								class="mb-6 flex items-center justify-between font-bold text-slate-100"
							>
								Fellow Seekers
								<a
									href="/social/seekers"
									class="text-xs font-medium uppercase tracking-tight text-primary hover:underline"
									>See all</a
								>
							</h3>
							<div class="flex flex-col gap-5">
								<div class="flex items-center gap-3">
									<div
										class="size-10 rounded-full border border-primary/20 bg-cover bg-center"
										style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBMc27Km3W7ofFHvPqKA_eH4UkvpFjaTpMosurD26-WU5a0L1er2Tbv2yXvMThCZYySx1MWmEvwK0aiW8AAzYeBaxrRWCn7ojlApEKaQm7TXu4TCNySe-gwS0Fw03FiIzaxtVZNHBB8CLHFRbvd0Yy6CWKz60FO2-Hfbmjerf36LRH_vtMbMoZliMf5y70OB1HuHHZ8L8eGxhYvGNl3oeh_3Wh2ZfGzVZ72HJwovHb1b9S5SiMLvMBYzA6Kwa0PVSRanUEbY_8gPTg')"
									>
									</div>
									<div class="min-w-0 flex-1">
										<p class="truncate text-sm font-bold">
											Julian Thorne
										</p>
										<p
											class="truncate text-xs text-slate-500"
										>
											Adept Seeker • 12 Artifacts
										</p>
									</div>
									<button
										class="rounded-full p-1 text-primary transition-colors hover:bg-primary/10"
									>
										<span
											class="material-symbols-outlined text-[20px]"
											>person_add</span
										>
									</button>
								</div>
								<div class="flex items-center gap-3">
									<div
										class="size-10 rounded-full border border-primary/20 bg-cover bg-center"
										style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCOnalM5JxNCVOnJvmJWZ3YNf6msFRvyleltNAQTdms6vYXSovMjcKzDSXjw_jvdW3rYTl7F8NguSaRGh5tGRrcgw3EYQMb8qNLWp2gliiku4a8MVJyTjbBkgvFVD8FDJ6eAbqu2SLoUMWh8yZQjnNQR6GFPlS-yTRnSrfC_5-V17QH3bokxQaVlmyIYVmfiQ2fCm4hBEHri50yl_qk7c2zObFWPmKeG3j_mih8V8UCsNhIcFeSyOiftz-IAWVHl9hH-SBcm7qsRzI')"
									>
									</div>
									<div class="min-w-0 flex-1">
										<p class="truncate text-sm font-bold">
											Lyra Moonshade
										</p>
										<p
											class="truncate text-xs text-slate-500"
										>
											Chronocologist • 8 Artifacts
										</p>
									</div>
									<button
										class="rounded-full p-1 text-primary transition-colors hover:bg-primary/10"
									>
										<span
											class="material-symbols-outlined text-[20px]"
											>person_add</span
										>
									</button>
								</div>
								<div class="flex items-center gap-3">
									<div
										class="size-10 rounded-full border border-primary/20 bg-cover bg-center"
										style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuAo5c0xM8L_C01ikYz9VpM5mb3f2vXXFp683EAZFX_jZcMkaMVYqkivUnTkyVdgAV-YL1sAALHZxPEAQ27yIwT7KHgTj1SlwBBRaYNcNFXPdWgwwEK_7xJQFEEaESmyW7c4CDWrYtymLZGLOZ4T75C1evT1ISkuhdOE1yhSUHs1c38zjTjdA3CVvvwjvPZgyzNiKk0uRXHVmEXhlJsne6bPpWlLRxe_2DATzKXinFJ-AdIvPfkwj_2Xgo5apcqR3GOqvW8Nw2tBf_M')"
									>
									</div>
									<div class="min-w-0 flex-1">
										<p class="truncate text-sm font-bold">
											Bram Van Der Berg
										</p>
										<p
											class="truncate text-xs text-slate-500"
										>
											Rune Smith • 25 Artifacts
										</p>
									</div>
									<button
										class="rounded-full p-1 text-primary transition-colors hover:bg-primary/10"
									>
										<span
											class="material-symbols-outlined text-[20px]"
											>person_add</span
										>
									</button>
								</div>
							</div>
						</div>

						<div
							class="relative mt-8 overflow-hidden rounded-xl border border-primary/20 bg-linear-to-br from-primary/20 to-transparent p-6"
						>
							<span
								class="material-symbols-outlined absolute -bottom-4 -right-4 text-7xl text-primary/10"
								>auto_stories</span
							>
							<h4
								class="mb-2 text-sm font-bold uppercase tracking-widest text-primary"
							>
								Library Notice
							</h4>
							<p
								class="relative z-10 text-sm italic text-slate-300"
							>
								"The Restricted Section will be open for a lunar
								phase starting tomorrow. Prepare your protection
								charms."
							</p>
						</div>
					</aside>
				</main>

				<SiteFooter />
			</div>
		</div>
	</body>
</html>
