---
import "../../styles/global.css";
import SiteFooter from "../../components/SiteFooter.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import { createAuthedClient } from "../../lib/supabase";
import { requireAuth } from "../../lib/api-auth";

export const prerender = false;

// Auth required for the social feed
const auth = await requireAuth(Astro.request);
const isLoggedIn = !auth.error;
const db = isLoggedIn ? createAuthedClient(auth.token!) : null;

let posts: any[] = [];
const currentUserId: string | null = isLoggedIn ? auth.userId : null;

// Fetch user's own profile for the create-post avatar
let myProfile: {
	id: string;
	username: string | null;
	avatar_url: string | null;
} | null = null;

if (db) {
	// Fetch posts with joins
	const { data: postsData } = await db
		.from("posts")
		.select(
			`
            id,
            content,
            author_id,
            story_id,
            character_id,
            image_urls,
            visibility,
            like_count,
            comment_count,
            repost_count,
            created_at,
            updated_at,
            author:profiles!posts_author_id_fkey(id, username, avatar_url),
            story:stories!posts_story_id_fkey(id, title),
            character:characters!posts_character_id_fkey(id, name, avatar_url)
        `,
		)
		.eq("is_deleted", false)
		.eq("visibility", "public")
		.order("created_at", { ascending: false })
		.limit(20);

	posts = (postsData || []) as any[];

	// Get liked/reposted status for current user
	if (posts.length > 0) {
		const postIds = posts.map((p: any) => p.id);
		const [{ data: likes }, { data: reposts }] = await Promise.all([
			db
				.from("post_likes")
				.select("post_id")
				.in("post_id", postIds)
				.eq("user_id", auth.userId),
			db
				.from("post_reposts")
				.select("post_id")
				.in("post_id", postIds)
				.eq("user_id", auth.userId),
		]);
		const likedSet = new Set((likes || []).map((l: any) => l.post_id));
		const repostedSet = new Set((reposts || []).map((r: any) => r.post_id));
		posts = posts.map((p: any) => ({
			...p,
			liked_by_me: likedSet.has(p.id),
			reposted_by_me: repostedSet.has(p.id),
		}));
	}

	// Fetch user's own profile for the create-post avatar
	const { data: profileData } = await db
		.from("profiles")
		.select("id, username, avatar_url")
		.eq("id", auth.userId)
		.single();
	myProfile = profileData as typeof myProfile;
}

// Helper: relative time formatting
function timeAgo(dateStr: string): string {
	const now = Date.now();
	const then = new Date(dateStr).getTime();
	const diff = now - then;
	const mins = Math.floor(diff / 60000);
	if (mins < 1) return "just now";
	if (mins < 60) return `${mins}m ago`;
	const hours = Math.floor(mins / 60);
	if (hours < 24) return `${hours}h ago`;
	const days = Math.floor(hours / 24);
	if (days < 7) return `${days}d ago`;
	return new Date(dateStr).toLocaleDateString();
}

const defaultAvatar = "/default_user_profile.png";
const myAvatarUrl =
	(myProfile as { avatar_url: string | null } | null)?.avatar_url ||
	defaultAvatar;

const postsJson = JSON.stringify(
	posts.map((p: any) => ({
		...p,
		created_at: p.created_at,
		author: p.author,
		story: p.story,
		character: p.character,
		timeAgo: timeAgo(p.created_at),
		image_urls: p.image_urls || [],
	})),
);

const isLoggedInJson = JSON.stringify(isLoggedIn);
const currentUserIdJson = JSON.stringify(currentUserId);
---

<html class="dark" lang="en">
	<head>
		<meta charset="utf-8" />
		<meta content="width=device-width, initial-scale=1.0" name="viewport" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>The Hall of Echoes - The Whispering Library</title>
		<link
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
