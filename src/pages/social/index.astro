												maxlength="5000"
											/>
											<div class="mt-4 flex items-center justify-between border-t border-primary/10 pt-4">
												<div class="flex gap-4 text-slate-500">
													<button
														id="attach-image-btn"
														class="flex items-center gap-1 transition-colors hover:text-accent-gold"
														title="Attach image"
													>
														<span class="material-symbols-outlined text-[20px]">
															image
														</span>
													</button>
													<button
														id="attach-story-btn"
														class="flex items-center gap-1 transition-colors hover:text-accent-gold"
														title="Attach story"
													>
														<span class="material-symbols-outlined text-[20px]">
															auto_stories
														</span>
													</button>
													<button
														id="attach-character-btn"
														class="flex items-center gap-1 transition-colors hover:text-accent-gold"
														title="Attach character"
													>
														<span class="material-symbols-outlined text-[20px]">
															token
														</span>
													</button>
												</div>
												<button
													id="submit-post-btn"
													class="rounded-lg bg-primary px-6 py-2 text-sm font-bold text-white shadow-lg shadow-primary/30 transition-all hover:bg-primary/90 hover:scale-105 disabled:opacity-50 disabled:cursor-not-allowed"
												>
													Echo
