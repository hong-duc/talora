		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="min-h-screen bg-background-dark text-slate-100">
		<div
			class="relative flex min-h-screen w-full flex-col overflow-x-hidden"
		>
			<div class="layout-container flex h-full grow flex-col">
				<SiteHeader activeSection="social" />

				<main
					class="mx-auto flex w-full max-w-360 flex-1 flex-col gap-10 px-6 py-10 md:flex-row lg:px-20"
				>
					<!-- LEFT SIDEBAR -->
					<aside class="w-full shrink-0 md:w-64">
						<div
							class="glass-card ethereal-glow relative overflow-hidden rounded-xl border border-primary/20 p-6"
						>
							<div
								class="absolute -left-px -top-px h-6 w-6 border-l-2 border-t-2 border-accent-gold/40 rounded-tl-lg"
							>
							</div>
							<div
								class="absolute -right-px -top-px h-6 w-6 border-r-2 border-t-2 border-accent-gold/40 rounded-tr-lg"
							>
							</div>
							<div
								class="absolute -bottom-px -left-px h-6 w-6 border-b-2 border-l-2 border-accent-gold/40 rounded-bl-lg"
							>
							</div>
							<div
								class="absolute -bottom-px -right-px h-6 w-6 border-b-2 border-r-2 border-accent-gold/40 rounded-br-lg"
							>
							</div>
							<h3 class="font-display mb-1 text-lg font-bold">
								<span class="gold-shimmer">The Sanctum</span>
							</h3>
							<p class="mb-6 text-sm text-slate-400">
								Seeker Rank: High Archivist
							</p>
							<nav class="flex flex-col gap-2">
								<a
									class="flex items-center gap-3 rounded-lg border border-accent-gold/30 bg-accent-gold/10 px-3 py-2.5 text-accent-gold"
									href="/social"
								>
									<span
										class="material-symbols-outlined text-[20px]"
										>forum</span
									>
									<span class="text-sm font-medium"
										>Hall of Echoes</span
									>
								</a>
								<a
									class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-slate-400 transition-colors hover:bg-primary/10 hover:text-primary"
									href="/user/my-stories"
								>
									<span
										class="material-symbols-outlined text-[20px]"
										>menu_book</span
									>
									<span class="text-sm font-medium"
										>My Library</span
									>
								</a>
								<a
									class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-slate-400 transition-colors hover:bg-primary/10 hover:text-primary"
									href="/user/reading-list"
								>
									<span
										class="material-symbols-outlined text-[20px]"
										>diamond</span
									>
									<span class="text-sm font-medium"
										>Artifact Gallery</span
									>
								</a>
								<a
									class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-slate-400 transition-colors hover:bg-primary/10 hover:text-primary"
									href="/social/seekers"
								>
									<span
										class="material-symbols-outlined text-[20px]"
										>groups</span
									>
									<span class="text-sm font-medium"
										>Fellow Seekers</span
									>
								</a>
							</nav>
						</div>
					</aside>

					<!-- MAIN FEED -->
					<section class="min-w-0 flex-1 flex-col gap-8 md:flex">
						<div>
							<h1
								class="font-display text-4xl font-black tracking-tight text-slate-100"
							>
								The Hall of <span class="gold-shimmer"
									>Echoes</span
								>
							</h1>
							<div
								class="mt-1 h-1 w-24 rounded-full bg-linear-to-r from-primary via-accent-gold to-primary"
