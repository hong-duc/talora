							</div>
							<p class="mt-2 text-slate-400">
								A communal space for seekers of lost knowledge
								and whispered tales.
							</p>
						</div>

						<!-- Create Post Box -->
						{
							isLoggedIn ? (
								<div class="ethereal-glow rounded-xl border border-primary/20 bg-surface-container p-4">
									<div class="flex gap-4">
										<div
											class="size-12 shrink-0 rounded-full border border-accent-gold/30 bg-cover bg-center"
											style={{
												backgroundImage: `url('${myAvatarUrl}')`,
											}}
										/>
										<div class="flex-1">
											<textarea
												id="create-post-textarea"
												class="w-full resize-none border-none bg-transparent text-lg italic text-slate-100 placeholder:text-slate-500 focus:ring-0"
												placeholder="Share a discovery or a whisper..."
												rows="2"
												maxlength="5000"
											/>
											<div class="mt-4 flex items-center justify-between border-t border-primary/10 pt-4">
												<div class="flex gap-4 text-slate-500">
													<button
														id="attach-image-btn"
														class="flex items-center gap-1 transition-colors hover:text-accent-gold"
														title="Attach image"
													>
														<span class="material-symbols-outlined text-[20px]">
															image
