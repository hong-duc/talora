---
/**
 * The Order of Seekers — public user directory
 *
 * Fetches all public profiles server-side (id, username, avatar_url),
 * then hands the full list to the client for:
 *   - username search (client-side filter, no server round-trips)
 *   - avatar grid rendering
 *   - pagination
 *   - follow/unfollow buttons
 */
import "../../styles/global.css";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { supabase } from "../../lib/supabase";
import { createAuthedClient } from "../../lib/supabase";
import { requireAuth } from "../../lib/api-auth";

export const prerender = false;

// Auth (optional)
const auth = await requireAuth(Astro.request);
const isLoggedIn = !auth.error;
const currentUserId: string | null = isLoggedIn ? auth.userId : null;

// Load all public profiles
type ProfileRow = {
    id: string;
    username: string | null;
    avatar_url: string | null;
};

let profiles: ProfileRow[] = [];

const { data, error } = await supabase
    .from("profiles")
    .select("id, username, avatar_url")
    .order("username", { ascending: true });

if (!error && data) {
    profiles = data as ProfileRow[];
}

// If logged in, fetch which users the current user already follows
let followingIds: string[] = [];

if (isLoggedIn && currentUserId) {
    const db = createAuthedClient(auth.token!);
    const { data: follows } = await db
        .from("user_followers")
        .select("following_id")
        .eq("follower_id", currentUserId);

    followingIds = (follows || []).map((f: any) => f.following_id);
}

const profilesJson = JSON.stringify(profiles);
const followingIdsJson = JSON.stringify(followingIds);
const isLoggedInJson = JSON.stringify(isLoggedIn);
const currentUserIdJson = JSON.stringify(currentUserId);
---

<html class="dark" lang="en">
    <head>
        <meta charset="utf-8" />
        <meta content="width=device-width, initial-scale=1.0" name="viewport" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>The Order of Seekers – The Whispering Library</title>
        <link
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
            rel="stylesheet"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&display=swap"
            rel="stylesheet"
        />
    </head>
    <body class="min-h-screen bg-background-dark font-display text-slate-100">
        <div
            class="relative flex min-h-screen w-full flex-col overflow-x-hidden"
        >
            <div class="layout-container flex h-full grow flex-col">
                <SiteHeader activeSection="seekers" />

                <main
                    class="mx-auto w-full max-w-6xl flex-1 px-6 py-10 lg:px-20"
                >
                    <!-- Page heading -->
                    <div class="mb-8">
                        <h1
                            class="font-display text-4xl font-black tracking-tight text-slate-100"
                        >
                            The Order of <span class="gold-shimmer"
                                >Seekers</span
                            >
                        </h1>
                        <div
                            class="mt-1 h-1 w-24 rounded-full bg-linear-to-r from-primary via-accent-gold to-primary"
                        >
                        </div>
                        <p class="mt-2 text-slate-400">
                            Discover fellow readers and authors wandering the
                            library's halls.
                        </p>
                    </div>

                    <!-- Username search bar -->
                    <div class="group relative mb-10">
                        <div
                            class="absolute -inset-1 rounded-xl bg-linear-to-r from-primary via-accent-gold to-purple-400 opacity-20 blur transition duration-1000 group-focus-within:opacity-50 group-hover:opacity-30 group-hover:duration-200"
                        >
                        </div>
                        <label
                            class="glass-card relative flex h-14 w-full items-center overflow-hidden rounded-xl border border-primary/30"
                        >
                            <span
                                class="material-symbols-outlined px-4 text-xl text-accent-gold"
                                >person_search</span
                            >
                            <input
                                aria-label="Search seekers by username"
                                class="w-full border-none bg-transparent text-base italic text-slate-100 placeholder:text-slate-500 focus:ring-0 focus:outline-none"
                                id="seeker-search"
                                placeholder="Search seekers by name…"
                                type="search"
                            />
                        </label>
                    </div>

                    <!-- Results count -->
                    <div class="mb-6 flex items-center justify-between gap-4">
                        <p class="text-sm text-slate-400">
                            Showing <span
                                id="result-count"
                                class="font-bold text-primary">0</span
                            > seekers
                        </p>
                        <p class="text-sm text-slate-500" id="page-indicator">
                        </p>
                    </div>

                    <!-- Avatar grid (populated by JS) -->
                    <div
                        id="seekers-grid"
                        class="grid grid-cols-2 gap-6 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6"
                    >
                        {
                            Array.from({ length: 12 }).map(() => (
                                <div class="animate-pulse flex flex-col items-center gap-3">
                                    <div class="size-24 rounded-full bg-primary/10" />
                                    <div class="h-3 w-16 rounded bg-primary/10" />
                                </div>
                            ))
                        }
                    </div>

                    <!-- Empty state -->
                    <div
                        id="empty-state"
                        class="hidden flex-col items-center gap-4 py-24 text-center"
                    >
                        <span
                            class="material-symbols-outlined text-6xl text-primary/30"
                            >search_off</span
                        >
                        <p class="text-xl font-bold">No seekers found</p>
                        <p class="text-slate-400">
                            Try a different name or clear the search.
                        </p>
                    </div>

                    <!-- Pagination -->
                    <div
                        id="pagination"
                        class="mt-10 flex items-center justify-center gap-2 flex-wrap"
                    >
                    </div>
                </main>

                <SiteFooter />
            </div>
        </div>

        <!-- Client-side: search + pagination + render + follow -->
        <script
            define:vars={{
                profilesJson,
                followingIdsJson,
                isLoggedInJson,
                currentUserIdJson,
            }}
        >
            (function () {
                const PER_PAGE = 24;
                const DEFAULT_AVATAR = "/default_user_profile.png";
                const profiles = JSON.parse(profilesJson);
                const followingIds = new Set(JSON.parse(followingIdsJson));
                const isLoggedIn = JSON.parse(isLoggedInJson);
                const currentUserId = JSON.parse(currentUserIdJson);

                let followingSet = new Set(followingIds);
                let currentQuery = "";
                let currentPage = 1;

                const grid = document.getElementById("seekers-grid");
                const paginationEl = document.getElementById("pagination");
                const searchInput = document.getElementById("seeker-search");
                const resultCount = document.getElementById("result-count");
                const pageIndicator = document.getElementById("page-indicator");
                const emptyState = document.getElementById("empty-state");

                // Helper: get cookie
                function getCookie(name) {
                    var cookies = document.cookie.split("; ");
                    for (var i = 0; i < cookies.length; i++) {
                        var idx = cookies[i].indexOf("=");
                        if (idx > -1) {
                            var key = cookies[i].slice(0, idx);
                            var val = cookies[i].slice(idx + 1);
                            if (key === name) return val;
                        }
                    }
                    return null;
                }

                // Escape HTML
                function escapeHtml(str) {
                    return str
                        .replace(/&/g, "&")
                        .replace(/</g, "<")
                        .replace(/>/g, ">")
                        .replace(/"/g, "&#34;");
                }

                // Filter
                function filterUsers(query) {
                    if (!query.trim()) return profiles;
                    var q = query.trim().toLowerCase();
                    return profiles.filter(function (u) {
                        return (
                            (u.username || "").toLowerCase().indexOf(q) !== -1
                        );
                    });
                }

                // Paginate
                function paginate(list, page) {
                    var start = (page - 1) * PER_PAGE;
                    return list.slice(start, start + PER_PAGE);
                }

                // Build a single seeker card
                function buildCard(user) {
                    var name = user.username || "Seeker";
                    var avatar = user.avatar_url || DEFAULT_AVATAR;
                    var safeId = encodeURIComponent(user.id);
                    var safeName = escapeHtml(name);
                    var safeAvatarUrl = avatar
                        .replace(/"/g, "&#34;")
                        .replace(/'/g, "&#39;");

                    var isSelf = user.id === currentUserId;
                    var isFollowing = followingSet.has(user.id);

                    var followBtn = "";
                    if (isLoggedIn && !isSelf) {
                        var followClass = isFollowing
                            ? "bg-accent-gold/20 text-accent-gold border border-accent-gold/40 hover:bg-accent-gold/30"
                            : "bg-primary/20 text-primary border border-primary/30 hover:bg-primary/30";
                        var followText = isFollowing ? "Following" : "Follow";
                        followBtn =
                            '<button class="follow-btn mt-2 rounded-full px-3 py-1 text-xs font-medium transition-all ' +
                            followClass +
                            '" data-user-id="' +
                            safeId +
                            '" data-following="' +
                            (isFollowing ? "1" : "0") +
                            '">' +
                            followText +
                            "</button>";
                    }

                    return (
                        '<div class="seeker-card group flex flex-col items-center gap-2 rounded-xl p-4 transition-all duration-200 hover:bg-primary/10">' +
                        '<a href="/user/' +
                        safeId +
                        '" class="flex flex-col items-center gap-2" title="' +
                        safeName +
                        '">' +
                        '<div class="size-24 shrink-0 rounded-full border-2 border-primary/30 bg-cover bg-center bg-primary/10 transition-all duration-200 group-hover:border-accent-gold group-hover:scale-105 group-hover:shadow-lg group-hover:shadow-accent-gold/20" style="background-image: url(\'' +
                        safeAvatarUrl +
                        '\')" aria-hidden="true"></div>' +
                        '<span class="max-w-full truncate text-center text-sm font-medium text-slate-200 group-hover:text-accent-gold">' +
                        safeName +
                        "</span>" +
                        "</a>" +
                        followBtn +
                        "</div>"
                    );
                }

                // Render grid
                function renderGrid(filtered) {
                    var page = paginate(filtered, currentPage);

                    if (filtered.length === 0) {
                        grid.innerHTML = "";
                        emptyState.classList.remove("hidden");
                        emptyState.classList.add("flex");
                    } else {
                        emptyState.classList.add("hidden");
                        emptyState.classList.remove("flex");
                        grid.innerHTML = page.map(buildCard).join("");

                        // Wire follow buttons
                        grid.querySelectorAll(".follow-btn").forEach(
                            function (btn) {
                                btn.addEventListener("click", function (e) {
                                    e.preventDefault();
                                    handleFollow(btn);
                                });
                            },
                        );
                    }

                    resultCount.textContent = String(filtered.length);

                    var totalPages = Math.ceil(filtered.length / PER_PAGE);
                    if (totalPages > 1) {
                        pageIndicator.textContent =
                            "Page " + currentPage + " of " + totalPages;
                    } else {
                        pageIndicator.textContent = "";
                    }
                }

                // Follow/unfollow
                async function handleFollow(btn) {
                    if (!isLoggedIn) {
                        window.location.href = "/signin";
                        return;
                    }

                    var userId = btn.getAttribute("data-user-id");
                    var isFollowing =
                        btn.getAttribute("data-following") === "1";
                    var token = getCookie("sb-access-token");

                    btn.setAttribute("disabled", "true");
                    btn.textContent = isFollowing
                        ? "Unfollowing..."
                        : "Following...";

                    try {
                        var res = await fetch(
                            "/api/user/" + userId + "/follow",
                            {
                                method: isFollowing ? "DELETE" : "POST",
                                headers: {
                                    "Content-Type": "application/json",
                                    Authorization: "Bearer " + token,
                                },
                            },
                        );
                        var data = await res.json();

                        if (res.ok) {
                            if (isFollowing) {
                                followingSet.delete(userId);
                                btn.setAttribute("data-following", "0");
                                btn.textContent = "Follow";
                                btn.className =
                                    "follow-btn mt-2 rounded-full px-3 py-1 text-xs font-medium transition-all bg-primary/20 text-primary border border-primary/30 hover:bg-primary/30";
                            } else {
                                followingSet.add(userId);
                                btn.setAttribute("data-following", "1");
                                btn.textContent = "Following";
                                btn.className =
                                    "follow-btn mt-2 rounded-full px-3 py-1 text-xs font-medium transition-all bg-accent-gold/20 text-accent-gold border border-accent-gold/40 hover:bg-accent-gold/30";
                            }
                        }
                    } catch (err) {
                        console.error("Follow error:", err);
                    } finally {
                        btn.removeAttribute("disabled");
                    }
                }

                // Pagination button builder
                function buildPageBtn(label, targetPage, isActive, isDisabled) {
                    var baseClass =
                        "flex h-9 min-w-[36px] items-center justify-center rounded-lg border px-3 text-sm font-medium transition-colors";
                    var activeClass = "border-primary bg-primary text-white";
                    var inactiveClass =
                        "border-primary/20 bg-primary/5 text-slate-300 hover:bg-primary/20 hover:border-primary/50";
                    var disabledClass =
                        "border-primary/10 bg-transparent text-slate-600 cursor-not-allowed";

                    var cls = isDisabled
                        ? baseClass + " " + disabledClass
                        : isActive
                          ? baseClass + " " + activeClass
                          : baseClass + " " + inactiveClass;

                    return (
                        '<button class="' +
                        cls +
                        '" data-page="' +
                        targetPage +
                        '" ' +
                        (isDisabled ? "disabled" : "") +
                        ">" +
                        label +
                        "</button>"
                    );
                }

                function renderPagination(filtered) {
                    var totalPages = Math.ceil(filtered.length / PER_PAGE);
                    if (totalPages <= 1) {
                        paginationEl.innerHTML = "";
                        return;
                    }

                    var html = "";
                    html += buildPageBtn(
                        '<span class="material-symbols-outlined text-base leading-none">chevron_left</span>',
                        currentPage - 1,
                        false,
                        currentPage === 1,
                    );

                    var range = buildPageRange(currentPage, totalPages);
                    for (var i = 0; i < range.length; i++) {
                        var item = range[i];
                        if (item === "...") {
                            html +=
                                '<span class="flex h-9 w-9 items-center justify-center text-slate-500">...</span>';
                        } else {
                            html += buildPageBtn(
                                String(item),
                                item,
                                item === currentPage,
                                false,
                            );
                        }
                    }

                    html += buildPageBtn(
                        '<span class="material-symbols-outlined text-base leading-none">chevron_right</span>',
                        currentPage + 1,
                        false,
                        currentPage === totalPages,
                    );

                    paginationEl.innerHTML = html;

                    paginationEl
                        .querySelectorAll("button[data-page]")
                        .forEach(function (btn) {
                            btn.addEventListener("click", function () {
                                var target = parseInt(
                                    btn.getAttribute("data-page"),
                                    10,
                                );
                                if (
                                    !isNaN(target) &&
                                    target >= 1 &&
                                    target <= totalPages
                                ) {
                                    currentPage = target;
                                    refresh();
                                    grid.scrollIntoView({
                                        behavior: "smooth",
                                        block: "start",
                                    });
                                }
                            });
                        });
                }

                function buildPageRange(current, total) {
                    if (total <= 7) {
                        return Array.from({ length: total }, function (_, i) {
                            return i + 1;
                        });
                    }
                    var pages = new Set();
                    pages.add(1);
                    pages.add(2);
                    pages.add(total - 1);
                    pages.add(total);
                    for (var i = current - 2; i <= current + 2; i++) {
                        if (i >= 1 && i <= total) pages.add(i);
                    }
                    var sorted = Array.from(pages).sort(function (a, b) {
                        return a - b;
                    });
                    var result = [];
                    for (var j = 0; j < sorted.length; j++) {
                        result.push(sorted[j]);
                        if (
                            j < sorted.length - 1 &&
                            sorted[j + 1] - sorted[j] > 1
                        ) {
                            result.push("...");
                        }
                    }
                    return result;
                }

                function refresh() {
                    var filtered = filterUsers(currentQuery);
                    renderGrid(filtered);
                    renderPagination(filtered);
                }

                var debounceTimer;
                searchInput.addEventListener("input", function (e) {
                    clearTimeout(debounceTimer);
                    debounceTimer = setTimeout(function () {
                        currentQuery = e.target.value;
                        currentPage = 1;
                        refresh();
                    }, 200);
                });

                refresh();
            })();
        </script>
    </body>
</html>
