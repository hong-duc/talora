---
export const prerender = true;

import "../styles/global.css";
import ArcaneButton from "../components/ArcaneButton.svelte";
---

<html class="dark" lang="en">
	<head>
		<meta charset="utf-8" />
		<meta content="width=device-width, initial-scale=1.0" name="viewport" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>The Whispering Library - Portal to the Archive</title>
		<link
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
			rel="stylesheet"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="min-h-screen bg-background-dark font-display text-slate-100">
		<div
			class="relative flex min-h-screen w-full flex-col overflow-x-hidden"
		>
			<main
				class="relative z-10 flex min-h-screen items-center justify-center p-4 md:p-8"
			>
				<div
					class="grid w-full max-w-[1100px] grid-cols-1 overflow-hidden rounded-xl border border-primary/10 bg-slate-900/50 shadow-2xl lg:grid-cols-2"
				>
					<div
						class="relative hidden flex-col justify-end overflow-hidden bg-slate-950 p-12 lg:flex"
					>
						<div class="absolute inset-0 opacity-60">
							<img
								alt="Ancient dark library with glowing magical books"
								class="h-full w-full object-cover"
								src="/gate.png"
							/>
						</div>
						<div
							class="absolute inset-0 bg-linear-to-t from-slate-950 via-slate-950/40 to-transparent"
						>
						</div>
						<div class="relative z-10">
							<span
								class="mb-4 inline-block rounded-full border border-primary/50 bg-primary/30 px-3 py-1 text-xs font-bold uppercase tracking-widest text-primary"
								>Arcane Access</span
							>
							<h1
								class="mb-4 text-4xl font-black italic leading-tight text-white md:text-5xl"
							>
								Portal to the Archive
							</h1>
							<p class="max-w-md text-lg text-slate-300">
								"Knowledge is a light that never fades, if one
								knows which scroll to unroll in the dark."
							</p>
						</div>
					</div>

					<div class="flex flex-col justify-center p-8 md:p-12">
						<div class="mb-8">
							<h2 class="mb-2 text-3xl font-bold text-white">
								Welcome, Seeker
							</h2>
							<p class="text-slate-400">
								Enter your credentials to manifest your
								presence.
							</p>
						</div>

						<div class="mb-8 flex border-b border-primary/10">
							<button
								class="flex flex-col items-center justify-center border-b-[3px] border-primary px-6 pb-3 text-sm font-bold tracking-wide text-primary transition-all"
							>
								Sign In
							</button>
							<button
								class="flex flex-col items-center justify-center border-b-[3px] border-transparent px-6 pb-3 text-sm font-bold tracking-wide text-slate-500 transition-all hover:text-primary/70"
							>
								Register for a Seal
							</button>
						</div>

						<form id="signin-form" class="space-y-6">
							<div class="space-y-2">
								<label
									class="ml-1 text-sm font-semibold text-slate-300"
									>Username or Mystic Email</label
								>
								<div class="group relative">
									<span
										class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 transition-colors group-focus-within:text-primary"
										>person</span
									>
									<input
										id="signin-email"
										class="w-full rounded-xl border border-slate-700 bg-slate-800 py-4 pl-12 pr-4 text-slate-100 placeholder:text-slate-500 outline-none transition-all focus:border-primary focus:ring-2 focus:ring-primary/50"
										placeholder="The Wanderer"
										type="text"
									/>
								</div>
							</div>

							<div class="space-y-2">
								<div
									class="flex items-center justify-between px-1"
								>
									<label
										class="text-sm font-semibold text-slate-300"
										>Secret Incantation</label
									>
									<a
										class="text-xs text-primary hover:underline"
										href="#">Lost your key?</a
									>
								</div>
								<div class="group relative">
									<span
										class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 transition-colors group-focus-within:text-primary"
										>lock</span
									>
									<input
										id="signin-password"
										class="w-full rounded-xl border border-slate-700 bg-slate-800 py-4 pl-12 pr-4 text-slate-100 placeholder:text-slate-500 outline-none transition-all focus:border-primary focus:ring-2 focus:ring-primary/50"
										placeholder="••••••••••••"
										type="password"
									/>
								</div>
							</div>

							<div class="flex items-center gap-2 px-1">
								<input
									class="rounded border-slate-700 bg-transparent text-primary focus:ring-primary"
									id="remember"
									type="checkbox"
								/>
								<label
									class="text-sm text-slate-400"
									for="remember"
									>Preserve session in the stars</label
								>
							</div>

							<div class="space-y-4 pt-4">
								<ArcaneButton
									type="submit"
									icon="auto_fix_high"
									className="w-full py-4"
								>
									Summon Entry
								</ArcaneButton>

								<div class="relative py-4">
									<div
										class="absolute inset-0 flex items-center"
									>
										<div
											class="w-full border-t border-primary/10"
										>
										</div>
									</div>
									<div
										class="relative flex justify-center text-xs uppercase tracking-widest"
									>
										<span
											class="bg-[#1f1629] px-4 text-slate-500"
											>New to the Archive?</span
										>
									</div>
								</div>

								<a
									class="flex w-full items-center justify-center gap-2 rounded-xl border-2 border-primary/30 py-4 font-bold text-primary transition-all hover:border-primary/60"
									href="/registion"
								>
									<span class="material-symbols-outlined"
										>history_edu</span
									>
									Seek Membership
								</a>
							</div>
						</form>

						<div
							class="mt-8 flex justify-center gap-6 text-xs italic text-slate-500"
						>
							<a
								class="transition-colors hover:text-primary"
								href="#">Library Laws</a
							>
							<a
								class="transition-colors hover:text-primary"
								href="#">Privacy Rituals</a
							>
							<a
								class="transition-colors hover:text-primary"
								href="#">Contact the Librarian</a
							>
						</div>
					</div>
				</div>
			</main>

			<div
				class="pointer-events-none fixed bottom-0 left-0 h-1 w-full bg-linear-to-r from-transparent via-primary/50 to-transparent"
			>
			</div>
			<div
				class="pointer-events-none fixed -left-24 -top-24 h-96 w-96 rounded-full bg-primary/10 blur-[100px]"
			>
			</div>
			<div
				class="pointer-events-none fixed -bottom-24 -right-24 h-96 w-96 rounded-full bg-primary/10 blur-[100px]"
			>
			</div>
		</div>
		<script>
			import "../scripts/signin.ts";
		</script>
	</body>
</html>
