---
import '../styles/global.css';
import signinScript from '../scripts/signin.ts?url';
import ArcaneButton from '../components/ArcaneButton.svelte';
---

<html class="dark" lang="en">
	<head>
		<meta charset="utf-8" />
		<meta content="width=device-width, initial-scale=1.0" name="viewport" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>The Whispering Library - Portal to the Archive</title>
		<link
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
			rel="stylesheet"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="min-h-screen bg-background-dark font-display text-slate-100">
		<div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">
			<main class="relative z-10 flex min-h-screen items-center justify-center p-4 md:p-8">
				<div class="grid w-full max-w-[1100px] grid-cols-1 overflow-hidden rounded-xl border border-primary/10 bg-slate-900/50 shadow-2xl lg:grid-cols-2">
					<div class="relative hidden flex-col justify-end overflow-hidden bg-slate-950 p-12 lg:flex">
						<div class="absolute inset-0 opacity-60">
							<img
								alt="Ancient dark library with glowing magical books"
								class="h-full w-full object-cover"
								src="/gate.png"
							/>
						</div>
						<div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/40 to-transparent"></div>
						<div class="relative z-10">
							<span class="mb-4 inline-block rounded-full border border-primary/50 bg-primary/30 px-3 py-1 text-xs font-bold uppercase tracking-widest text-primary">Arcane Access</span>
							<h1 class="mb-4 text-4xl font-black italic leading-tight text-white md:text-5xl">Portal to the Archive</h1>
							<p class="max-w-md text-lg text-slate-300">"Knowledge is a light that never fades, if one knows which scroll to unroll in the dark."</p>
						</div>
					</div>

					<div class="flex flex-col justify-center p-8 md:p-12">
						<div class="mb-8">
							<h2 class="mb-2 text-3xl font-bold text-white">Welcome, Seeker</h2>
							<p class="text-slate-400">Enter your credentials to manifest your presence.</p>
						</div>

						<div class="mb-8 flex border-b border-primary/10">
							<button class="flex flex-col items-center justify-center border-b-[3px] border-primary px-6 pb-3 text-sm font-bold tracking-wide text-primary transition-all">
								Sign In
							</button>
							<button class="flex flex-col items-center justify-center border-b-[3px] border-transparent px-6 pb-3 text-sm font-bold tracking-wide text-slate-500 transition-all hover:text-primary/70">
								Register for a Seal
							</button>
						</div>

						<form id="signin-form" class="space-y-6">
							<div class="space-y-2">
								<label class="ml-1 text-sm font-semibold text-slate-300">Username or Mystic Email</label>
								<div class="group relative">
									<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 transition-colors group-focus-within:text-primary">person</span>
									<input
										id="signin-email"
										class="w-full rounded-xl border border-slate-700 bg-slate-800 py-4 pl-12 pr-4 text-slate-100 placeholder:text-slate-500 outline-none transition-all focus:border-primary focus:ring-2 focus:ring-primary/50"
										placeholder="The Wanderer"
										type="text"
									/>
								</div>
							</div>

							<div class="space-y-2">
								<div class="flex items-center justify-between px-1">
									<label class="text-sm font-semibold text-slate-300">Secret Incantation</label>
									<a class="text-xs text-primary hover:underline" href="#">Lost your key?</a>
								</div>
								<div class="group relative">
									<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 transition-colors group-focus-within:text-primary">lock</span>
									<input
										id="signin-password"
										class="w-full rounded-xl border border-slate-700 bg-slate-800 py-4 pl-12 pr-4 text-slate-100 placeholder:text-slate-500 outline-none transition-all focus:border-primary focus:ring-2 focus:ring-primary/50"
										placeholder="••••••••••••"
										type="password"
									/>
								</div>
							</div>

							<div class="flex items-center gap-2 px-1">
								<input class="rounded border-slate-700 bg-transparent text-primary focus:ring-primary" id="remember" type="checkbox" />
								<label class="text-sm text-slate-400" for="remember">Preserve session in the stars</label>
							</div>

							<div class="space-y-4 pt-4">
								<ArcaneButton type="submit" icon="auto_fix_high" className="w-full py-4">
									Summon Entry
								</ArcaneButton>

								<div class="relative py-4">
									<div class="absolute inset-0 flex items-center">
										<div class="w-full border-t border-primary/10"></div>
									</div>
									<div class="relative flex justify-center text-xs uppercase tracking-widest">
										<span class="bg-[#1f1629] px-4 text-slate-500">Or bind your soul via</span>
									</div>
								</div>

								<div class="mt-2 grid grid-cols-2 gap-4">
									<button class="flex items-center justify-center gap-2 rounded-xl border border-primary/10 bg-slate-800/50 px-4 py-3 text-sm font-semibold text-slate-300 transition-all hover:bg-slate-800">
										<svg class="h-4 w-4" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"></path><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"></path><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"></path><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"></path></svg>
										Bind with Google
									</button>
									<button class="flex items-center justify-center gap-2 rounded-xl border border-primary/10 bg-slate-800/50 px-4 py-3 text-sm font-semibold text-slate-300 transition-all hover:bg-slate-800">
										<svg class="h-4 w-4" fill="#5865F2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037 19.736 19.736 0 0 0-4.885 1.515.069.069 0 0 0-.032.027C.533 9.048-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.866-1.295 1.207-1.997a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128c.126-.094.252-.192.372-.29a.074.074 0 0 1 .077-.01c3.927 1.793 8.18 1.793 12.061 0a.074.074 0 0 1 .077.01c.12.098.246.196.373.29a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.874.89.076.076 0 0 0-.041.107c.345.703.748 1.368 1.21 1.998a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"></path></svg>
										Echo with Discord
									</button>
								</div>

								<div class="relative py-4">
									<div class="absolute inset-0 flex items-center">
										<div class="w-full border-t border-primary/10"></div>
									</div>
									<div class="relative flex justify-center text-xs uppercase tracking-widest">
										<span class="bg-[#1f1629] px-4 text-slate-500">New to the Archive?</span>
									</div>
								</div>

								<a
									class="flex w-full items-center justify-center gap-2 rounded-xl border-2 border-primary/30 py-4 font-bold text-primary transition-all hover:border-primary/60"
									href="/registion"
								>
									<span class="material-symbols-outlined">history_edu</span>
									Seek Membership
								</a>
							</div>
						</form>

						<div class="mt-8 flex justify-center gap-6 text-xs italic text-slate-500">
							<a class="transition-colors hover:text-primary" href="#">Library Laws</a>
							<a class="transition-colors hover:text-primary" href="#">Privacy Rituals</a>
							<a class="transition-colors hover:text-primary" href="#">Contact the Librarian</a>
						</div>
					</div>
				</div>
			</main>

			<div class="pointer-events-none fixed bottom-0 left-0 h-1 w-full bg-gradient-to-r from-transparent via-primary/50 to-transparent"></div>
			<div class="pointer-events-none fixed -left-24 -top-24 h-96 w-96 rounded-full bg-primary/10 blur-[100px]"></div>
			<div class="pointer-events-none fixed -bottom-24 -right-24 h-96 w-96 rounded-full bg-primary/10 blur-[100px]"></div>
		</div>
			<script is:inline type="module" src={signinScript}></script>
	</body>
</html>
